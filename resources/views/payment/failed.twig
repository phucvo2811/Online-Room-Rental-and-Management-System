{% extends 'layouts/base.twig' %}
{% block title %}{{ page_title }}{% endblock %}

{% block content %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">

            {# Failed icon #}
            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-danger text-white"
                     style="width:96px;height:96px;font-size:2.5rem">
                    <i class="bi bi-x-lg"></i>
                </div>
            </div>

            <h2 class="fw-800 mb-2">Thanh toán thất bại</h2>
            <p class="text-muted mb-4">{{ message }}</p>

            {% if payment %}
            <div class="card border-0 shadow-sm mb-4 text-start">
                <div class="card-body p-4">
                    <h6 class="fw-700 mb-3 text-muted text-uppercase small">Chi tiết giao dịch</h6>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Mã giao dịch</span>
                        <span class="fw-600 font-monospace">{{ payment.vnp_txn_ref }}</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Gói đã chọn</span>
                        <span class="fw-600">
                            {% if packages[payment.package_type] is defined %}
                                {{ packages[payment.package_type].label }}
                            {% else %}
                                {{ payment.package_type }}
                            {% endif %}
                        </span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Trạng thái</span>
                        <span class="badge bg-danger">{{ payment.status }}</span>
                    </div>
                    {% if payment.vnp_response_code %}
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Mã lỗi VNPay</span>
                        <span class="font-monospace text-danger">{{ payment.vnp_response_code }}</span>
                    </div>
                    {% endif %}
                </div>
            </div>
            {% endif %}

            <div class="d-flex gap-3 justify-content-center">
                <a href="{{ route('/payment/packages') }}" class="btn btn-primary rounded-pill px-4">
                    <i class="bi bi-arrow-repeat me-1"></i> Thử lại
                </a>
                <a href="{{ route('/dashboard') }}" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-house me-1"></i> Về trang chủ
                </a>
            </div>

        </div>
    </div>
</div>
{% endblock %}
