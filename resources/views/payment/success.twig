{% extends 'layouts/base.twig' %}
{% block title %}{{ page_title }}{% endblock %}

{% block content %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">

            {# Success icon #}
            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success text-white"
                     style="width:96px;height:96px;font-size:2.5rem">
                    <i class="bi bi-check-lg"></i>
                </div>
            </div>

            <h2 class="fw-800 mb-2">Thanh toán thành công!</h2>
            <p class="text-muted mb-4">{{ message }}</p>

            {% if payment %}
            <div class="card border-0 shadow-sm mb-4 text-start">
                <div class="card-body p-4">
                    <h6 class="fw-700 mb-3 text-muted text-uppercase small">Chi tiết giao dịch</h6>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Mã giao dịch</span>
                        <span class="fw-600 font-monospace">{{ payment.vnp_txn_ref }}</span>
                    </div>
                    {% if payment.vnp_transaction_no %}
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Mã VNPay</span>
                        <span class="fw-600 font-monospace">{{ payment.vnp_transaction_no }}</span>
                    </div>
                    {% endif %}
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Gói</span>
                        <span class="fw-600">
                            {% if packages[payment.package_type] is defined %}
                                {{ packages[payment.package_type].label }}
                            {% else %}
                                {{ payment.package_type }}
                            {% endif %}
                        </span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Số tiền</span>
                        <span class="fw-700 text-success">{{ payment.amount|number_format(0,',','.') }}đ</span>
                    </div>
                    {% if payment.vnp_bank_code %}
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Ngân hàng</span>
                        <span class="fw-600">{{ payment.vnp_bank_code }}</span>
                    </div>
                    {% endif %}
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Thời gian</span>
                        <span>{{ payment.created_at|date('H:i d/m/Y') }}</span>
                    </div>
                </div>
            </div>
            {% endif %}

            <div class="d-flex gap-3 justify-content-center">
                <a href="{{ route('/dashboard') }}" class="btn btn-primary rounded-pill px-4">
                    <i class="bi bi-speedometer2 me-1"></i> Vào Dashboard
                </a>
                <a href="{{ route('/payment/history') }}" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-clock-history me-1"></i> Lịch sử
                </a>
            </div>

        </div>
    </div>
</div>
{% endblock %}
