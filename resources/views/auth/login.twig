{% extends 'layouts/base.twig' %}
{% block title %}Đăng nhập{% endblock %}

{% block content %}
<div class="auth-page py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="auth-card">
                    <div class="auth-header">
                        <div class="brand-icon mx-auto mb-3" style="width:52px;height:52px;font-size:24px;">
                            <i class="bi bi-house-heart-fill"></i>
                        </div>
                        <h2 class="fw-800 mb-1 text-white">Đăng nhập</h2>
                        <p class="text-white-50 mb-0 small">Chào mừng trở lại {{ app_name }}</p>
                    </div>
                    <div class="auth-body">

                        {% if errors.general is defined %}
                            <div class="alert alert-danger py-2 small border-0 rounded-3">
                                <i class="bi bi-exclamation-triangle me-2"></i>{{ errors.general }}
                            </div>
                        {% endif %}

                        <form action="{{ route('/login') }}" method="POST" class="auth-form">
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-envelope text-muted"></i>
                                    </span>
                                    <input type="email" name="email"
                                        class="form-control border-start-0 ps-0 {{ errors.email is defined ? 'is-invalid' : '' }}"
                                        placeholder="your@email.com"
                                        value="{{ old.email ?? '' }}" required>
                                    {% if errors.email is defined %}
                                        <div class="invalid-feedback">{{ errors.email }}</div>
                                    {% endif %}
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Mật khẩu</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-lock text-muted"></i>
                                    </span>
                                    <input type="password" name="password" id="pwdField"
                                        class="form-control border-start-0 border-end-0 ps-0 {{ errors.password is defined ? 'is-invalid' : '' }}"
                                        placeholder="••••••••" required>
                                    <button type="button" class="input-group-text bg-light"
                                        onclick="togglePwd('pwdField',this)">
                                        <i class="bi bi-eye text-muted"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <label class="d-flex align-items-center gap-2 small">
                                    <input type="checkbox" name="remember"> Ghi nhớ đăng nhập
                                </label>
                                <a href="#" class="small text-primary">Quên mật khẩu?</a>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 fw-700 py-2">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                            </button>
                        </form>

                        <div class="text-center mt-4 pt-3 border-top">
                            <span class="small text-muted">Chưa có tài khoản? </span>
                            <a href="{{ route('/register') }}" class="small fw-700">Đăng ký ngay</a>
                        </div>


                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function togglePwd(id, btn) {
    const f = document.getElementById(id), i = btn.querySelector('i');
    f.type = f.type === 'password' ? 'text' : 'password';
    i.className = f.type === 'password' ? 'bi bi-eye text-muted' : 'bi bi-eye-slash text-muted';
}
</script>
{% endblock %}