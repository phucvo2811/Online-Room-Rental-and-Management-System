{% extends 'layouts/admin.twig' %}
{% set active_page = 'dashboard' %}
{% block title %}Admin Dashboard{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h4 class="fw-800 mb-1">Tổng quan hệ thống</h4>
        <p class="text-muted small mb-0">
            Xin chào <strong>{{ auth.name }}</strong>! Hôm nay {{ "now"|date("d/m/Y") }}.
        </p>
    </div>
    <a href="{{ route('/admin/rooms') }}?status=pending" class="btn btn-warning btn-sm fw-600">
        <i class="bi bi-clock me-1"></i>Xem tin chờ duyệt
    </a>
</div>

<div class="row g-3 mb-4">
    {% set stat_cards = [
        {val: stats.total,    label: 'Tổng phòng đăng', icon: 'bi-house-door',  color: 'orange'},
        {val: stats.approved, label: 'Đã được duyệt',   icon: 'bi-check-circle',color: 'green'},
        {val: stats.pending,  label: 'Đang chờ duyệt',  icon: 'bi-hourglass',   color: 'blue'},
        {val: stats.users,    label: 'Tổng người dùng', icon: 'bi-people',      color: 'red'}
    ] %}
    {% for card in stat_cards %}
        <div class="col-sm-6 col-xl-3">
            <div class="dashboard-stat-card">
                <div class="stat-icon-box {{ card.color }}">
                    <i class="bi {{ card.icon }}"></i>
                </div>
                <div>
                    <div class="stat-val {{ card.label == 'Đang chờ duyệt' and stats.pending > 0 ? 'text-warning' : '' }}">
                        {{ card.val }}
                    </div>
                    <div class="stat-lbl">{{ card.label }}</div>
                </div>
            </div>
        </div>
    {% endfor %}
</div>

<div class="admin-table">
    <div class="d-flex justify-content-between align-items-center px-4 py-3 border-bottom">
        <h6 class="fw-700 mb-0">
            <i class="bi bi-clock-history me-2 text-warning"></i>
            Tin chờ duyệt ({{ pending|length }})
        </h6>
        <a href="{{ route('/admin/rooms') }}?status=pending" class="btn btn-sm btn-outline-primary">
            Xem tất cả
        </a>
    </div>

    {% if pending is empty %}
        <div class="text-center py-5 text-muted">
            <i class="bi bi-check-circle fs-1 text-success d-block mb-2"></i>
            <h6>Không có tin nào chờ duyệt!</h6>
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width:40%">Phòng trọ</th>
                        <th>Chủ trọ</th>
                        <th>Khu vực</th>
                        <th>Giá</th>
                        <th>Ngày đăng</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    {% for r in pending %}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    {% if r.primary_image %}
                                        <img src="{{ upload_url ~ r.primary_image }}"
                                            style="width:52px;height:40px;object-fit:cover;border-radius:8px;flex-shrink:0">
                                    {% else %}
                                        <div class="bg-light rounded d-flex align-items-center justify-content-center flex-shrink-0"
                                            style="width:52px;height:40px">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    {% endif %}
                                    <div>
                                        <div class="fw-600 small">{{ r.title|truncate(45) }}</div>
                                        <div class="text-muted" style="font-size:11px">
                                            {{ room_types[r.room_type] ?? r.room_type }}
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="small">
                                <div class="fw-500">{{ r.landlord_name }}</div>
                                <div class="text-muted">{{ r.landlord_phone }}</div>
                            </td>
                            <td class="small">{{ r.district_name }}</td>
                            <td class="fw-700 text-primary small">{{ r.price|money }}</td>
                            <td class="small text-muted">{{ r.created_at|date('d/m/Y') }}</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="{{ route('/rooms/' ~ r.id) }}" target="_blank"
                                        class="btn btn-sm btn-outline-secondary py-0 px-2">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <form action="{{ route('/admin/rooms/' ~ r.id ~ '/approve') }}"
                                          method="POST" class="d-inline">
                                        <button class="btn btn-sm btn-success py-0 px-2" title="Duyệt">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    </form>
                                    <button class="btn btn-sm btn-danger py-0 px-2"
                                        onclick="rejectRoom({{ r.id }})" title="Từ chối">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>

<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-700">Lý do từ chối</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="rejectForm" method="POST">
                <div class="modal-body">
                    <textarea name="reason" class="form-control" rows="3"
                        placeholder="Lý do từ chối..." required></textarea>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger btn-sm">Từ chối</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function rejectRoom(id) {
    document.getElementById('rejectForm').action = `{{ app_url }}/admin/rooms/${id}/reject`;
    new bootstrap.Modal(document.getElementById('rejectModal')).show();
}
</script>
{% endblock %}