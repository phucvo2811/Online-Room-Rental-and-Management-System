{% extends 'layouts/admin.twig' %}
{% set active_page = 'users' %}
{% block title %}Quản lý người dùng{% endblock %}

{% block admin_content %}
<h4 class="fw-800 mb-4">Quản lý người dùng ({{ users|length }})</h4>

<div class="admin-table">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Người dùng</th>
                    <th>Vai trò</th>
                    <th>Phòng đăng</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                {% for u in users %}
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="user-avatar-sm">{{ u.name|slice(0,1)|upper }}</div>
                                <div>
                                    <div class="fw-600 small">{{ u.name }}</div>
                                    <div class="text-muted" style="font-size:11px">{{ u.email }}</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="tag-pill">
                                {{ u.role == 'admin' ? '⚙️ Admin' : (u.role == 'landlord' ? '🏠 Chủ trọ' : '🔍 Người thuê') }}
                            </span>
                        </td>
                        <td class="small">{{ u.room_count ?? 0 }}</td>
                        <td>
                            <span class="status-badge {{ u.status == 'active' ? 'approved' : 'rejected' }}">
                                {{ u.status == 'active' ? 'Hoạt động' : (u.status == 'banned' ? 'Bị khóa' : 'Không HĐ') }}
                            </span>
                        </td>
                        <td class="small text-muted">{{ u.created_at|date('d/m/Y') }}</td>
                        <td>
                            {% if u.id != auth.id and u.role != 'admin' %}
                                <form action="{{ route('/admin/users/' ~ u.id ~ '/ban') }}" method="POST"
                                    onsubmit="return confirm('{{ u.status == 'banned' ? 'Mở khóa' : 'Khóa' }} tài khoản này?')">
                                    <button class="btn btn-sm {{ u.status == 'banned' ? 'btn-success' : 'btn-danger' }} py-0 px-2">
                                        <i class="bi bi-{{ u.status == 'banned' ? 'unlock' : 'lock' }} me-1"></i>
                                        {{ u.status == 'banned' ? 'Mở khóa' : 'Khóa' }}
                                    </button>
                                </form>
                            {% else %}
                                <span class="text-muted small">—</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}