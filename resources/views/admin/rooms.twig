{% extends 'layouts/admin.twig' %}
{% set active_page = 'rooms' %}
{% block title %}Quản lý phòng trọ{% endblock %}

{% block admin_content %}
<div class="d-flex gap-2 mb-4 flex-wrap align-items-center justify-content-between">
    <h4 class="fw-800 mb-0">Quản lý phòng trọ</h4>
    <div class="d-flex gap-2 flex-wrap">
        {% for s, l in {pending:'Chờ duyệt', approved:'Đã duyệt', rejected:'Từ chối', rented:'Đã thuê'} %}
            <a href="{{ route('/admin/rooms') }}?status={{ s }}"
                class="btn btn-sm {{ currentStatus == s ? 'btn-primary' : 'btn-outline-secondary' }}">
                {{ l }}
            </a>
        {% endfor %}
    </div>
</div>

<div class="admin-table">
    {% if rooms is empty %}
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
            <h6>Không có phòng nào</h6>
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width:42%">Phòng trọ</th>
                        <th>Chủ trọ</th>
                        <th>Giá</th>
                        <th>Trạng thái</th>
                        <th>Ngày đăng</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    {% for r in rooms %}
                        {% set si = room_status[r.status] ?? {label: r.status, class: 'secondary'} %}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    {% if r.primary_image %}
                                        <img src="{{ upload_url ~ r.primary_image }}"
                                            style="width:56px;height:42px;object-fit:cover;border-radius:8px;flex-shrink:0">
                                    {% else %}
                                        <div class="bg-light rounded d-flex align-items-center justify-content-center flex-shrink-0"
                                            style="width:56px;height:42px">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    {% endif %}
                                    <div>
                                        <div class="fw-600 small">{{ r.title|truncate(48) }}</div>
                                        <div class="text-muted" style="font-size:11px">
                                            <i class="bi bi-geo-alt me-1"></i>{{ r.district_name }}
                                            · {{ room_types[r.room_type] ?? r.room_type }}
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="small">
                                <div class="fw-500">{{ r.landlord_name }}</div>
                                <div class="text-muted">{{ r.landlord_phone }}</div>
                            </td>
                            <td class="fw-700 text-primary small">{{ r.price|money }}</td>
                            <td>
                                <span class="status-badge {{ r.status }}">{{ si.label }}</span>
                                {% if r.is_spam %}
                                    <span class="badge bg-warning text-dark ms-2">Nghi spam</span>
                                {% endif %}
                            </td>
                            <td class="small text-muted">{{ r.created_at|date('d/m/Y') }}</td>
                            <td>
                                <div class="d-flex gap-1 flex-wrap">
                                    <a href="{{ route('/rooms/' ~ r.id) }}" target="_blank"
                                        class="btn btn-sm btn-outline-secondary py-0 px-2">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    {% if r.status != 'approved' %}
                                        <form action="{{ route('/admin/rooms/' ~ r.id ~ '/approve') }}"
                                              method="POST" class="d-inline">
                                            <button class="btn btn-sm btn-success py-0 px-2">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                    {% endif %}
                                    {% if r.status != 'rejected' %}
                                        <button class="btn btn-sm btn-danger py-0 px-2"
                                            onclick="rejectRoom({{ r.id }})">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    {% endif %}
                                    <form action="{{ route('/admin/rooms/' ~ r.id ~ '/hide') }}" method="POST" class="d-inline">
                                        <button class="btn btn-sm btn-outline-secondary py-0 px-2">
                                            <i class="bi bi-eye-slash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>

<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-700">Lý do từ chối</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="rejectForm" method="POST">
                <div class="modal-body">
                    <textarea name="reason" class="form-control" rows="3"
                        placeholder="Lý do..." required></textarea>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger btn-sm">Từ chối</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function rejectRoom(id) {
    document.getElementById('rejectForm').action = `{{ app_url }}/admin/rooms/${id}/reject`;
    new bootstrap.Modal(document.getElementById('rejectModal')).show();
}
</script>
{% endblock %}