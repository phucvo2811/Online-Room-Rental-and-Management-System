{% extends 'layouts/base.twig' %}
{% block title %}Dashboard{% endblock %}

{% block content %}
<div class="container py-4">
    <div class="row g-4">

        {# Sidebar #}
        <div class="col-lg-3">
            <div class="filter-sidebar text-center">
                <div class="user-avatar-sm mx-auto mb-3"
                     style="width:72px;height:72px;font-size:32px;border-radius:50%;">
                    {% if auth.avatar %}
                        <img src="{{ upload_url ~ auth.avatar }}" alt="">
                    {% else %}
                        <span>{{ auth.name|slice(0,1)|upper }}</span>
                    {% endif %}
                </div>
                <h6 class="fw-700 mb-1">{{ auth.name }}</h6>
                <div class="tag-pill mb-3">
                    {{ auth.role == 'landlord' ? '🏠 Chủ trọ' : '🔍 Người thuê' }}
                </div>
                <ul class="nav flex-column text-start">
                    <li>
                        <a class="nav-link fw-500 active" href="{{ route('/dashboard') }}">
                            <i class="bi bi-speedometer2 me-2"></i>Dashboard
                        </a>
                    </li>
                    {% if auth.role == 'landlord' %}
                        <li>
                            <a class="nav-link" href="{{ route('/my-rooms') }}">
                                <i class="bi bi-house me-2"></i>Phòng của tôi
                            </a>
                        </li>
                        <li>
                            <a class="nav-link" href="{{ route('/rooms/create') }}">
                                <i class="bi bi-plus-circle me-2"></i>Đăng tin mới
                            </a>
                        </li>
                    {% endif %}
                    <li>
                        <a class="nav-link" href="{{ route('/favorites') }}">
                            <i class="bi bi-heart me-2"></i>Yêu thích
                        </a>
                    </li>
                    <li>
                        <a class="nav-link" href="{{ route('/profile') }}">
                            <i class="bi bi-person me-2"></i>Hồ sơ
                        </a>
                    </li>
                    <li>
                        <a class="nav-link text-danger" href="{{ route('/logout') }}">
                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        {# Main #}
        <div class="col-lg-9">
            <h4 class="fw-800 mb-4">Xin chào, {{ auth.name }}! 👋</h4>

            {% if auth.role == 'landlord' %}
                <div class="row g-3 mb-4">
                    {% set total_rooms    = myRooms|length %}
                    {% set approved_rooms = myRooms|filter(r => r.status == 'approved')|length %}
                    {% set pending_rooms  = myRooms|filter(r => r.status == 'pending')|length %}
                    <div class="col-sm-4">
                        <div class="dashboard-stat-card">
                            <div class="stat-icon-box orange"><i class="bi bi-house-door"></i></div>
                            <div>
                                <div class="stat-val">{{ total_rooms }}</div>
                                <div class="stat-lbl">Phòng đã đăng</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="dashboard-stat-card">
                            <div class="stat-icon-box green"><i class="bi bi-check-circle"></i></div>
                            <div>
                                <div class="stat-val">{{ approved_rooms }}</div>
                                <div class="stat-lbl">Đã duyệt</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="dashboard-stat-card">
                            <div class="stat-icon-box blue"><i class="bi bi-clock"></i></div>
                            <div>
                                <div class="stat-val {{ pending_rooms > 0 ? 'text-warning' : '' }}">
                                    {{ pending_rooms }}
                                </div>
                                <div class="stat-lbl">Chờ duyệt</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="room-detail-card mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-700 mb-0">
                            <i class="bi bi-house me-2 text-primary"></i>Phòng của tôi
                        </h6>
                        <a href="{{ route('/rooms/create') }}" class="btn btn-sm btn-primary">
                            <i class="bi bi-plus-lg me-1"></i>Đăng mới
                        </a>
                    </div>
                    {% if myRooms is empty %}
                        <div class="empty-state py-4">
                            <div class="icon"><i class="bi bi-house-add"></i></div>
                            <h6>Chưa có phòng nào</h6>
                            <a href="{{ route('/rooms/create') }}" class="btn btn-primary btn-sm">
                                Đăng tin đầu tiên
                            </a>
                        </div>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead>
                                    <tr><th>Phòng</th><th>Giá</th><th>Trạng thái</th><th></th></tr>
                                </thead>
                                <tbody>
                                    {% for r in myRooms|slice(0,5) %}
                                        {% set si = room_status[r.status] ?? {label:r.status,class:'secondary'} %}
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    {% if r.primary_image %}
                                                        <img src="{{ upload_url ~ r.primary_image }}"
                                                             style="width:44px;height:34px;object-fit:cover;border-radius:6px">
                                                    {% endif %}
                                                    <div class="small fw-600">{{ r.title|truncate(40) }}</div>
                                                </div>
                                            </td>
                                            <td class="small fw-700 text-primary">{{ r.price|money }}</td>
                                            <td>
                                                <span class="status-badge {{ r.status }}">{{ si.label }}</span>
                                            </td>
                                            <td>
                                                <a href="{{ route('/rooms/' ~ r.id ~ '/edit') }}"
                                                   class="btn btn-sm btn-outline-secondary py-0 px-2">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        {% if myRooms|length > 5 %}
                            <a href="{{ route('/my-rooms') }}" class="btn btn-outline-primary btn-sm mt-2">
                                Xem tất cả {{ myRooms|length }} phòng
                            </a>
                        {% endif %}
                    {% endif %}
                </div>
            {% endif %}

            {# Notifications #}
            <div class="room-detail-card mb-4">
                <h6 class="fw-700 mb-3">
                    <i class="bi bi-bell me-2 text-primary"></i>Thông báo gần đây
                </h6>
                {% if notifs is empty %}
                    <div class="text-center py-3 text-muted small">
                        <i class="bi bi-bell-slash fs-3 d-block mb-2"></i>
                        Chưa có thông báo nào
                    </div>
                {% else %}
                    {% for n in notifs|slice(0,5) %}
                        <div class="notif-item rounded-3 mb-1 {{ n.is_read ? '' : 'unread' }}">
                            <div class="notif-icon {{ n.type }}">
                                <i class="bi bi-info-circle"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="notif-title">{{ n.title }}</div>
                                {% if n.message %}
                                    <div class="small text-muted">{{ n.message }}</div>
                                {% endif %}
                                <div class="notif-time">{{ n.created_at|date('d/m/Y H:i') }}</div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>

            {% if favorites is not empty %}
                <div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-700 mb-0">
                            <i class="bi bi-heart me-2 text-danger"></i>Phòng yêu thích
                        </h6>
                        <a href="{{ route('/favorites') }}" class="btn btn-sm btn-outline-secondary">
                            Xem tất cả
                        </a>
                    </div>
                    <div class="row g-3">
                        {% for room in favorites|slice(0,4) %}
                            <div class="col-sm-6">
                                {% include 'components/_room_card.twig' with { room: room } %}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}