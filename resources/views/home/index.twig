{% extends 'layouts/base.twig' %}
{% block title %}Tìm phòng trọ uy tín tại Cần Thơ{% endblock %}
{% block meta_desc %}Tìm phòng trọ, căn hộ mini, nhà trọ uy tín tại Cần Thơ. Hàng trăm phòng đã xác thực, kết nối trực tiếp chủ trọ.{% endblock %}

{% block head %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css">
{% endblock %}

{% block content %}

{# ══════════════════════════════════════════════════════════
   SECTION 1 — HERO
══════════════════════════════════════════════════════════ #}
<section class="ho-hero">

    {# Floating glass cards — visible on large screens only #}
    <div class="ho-float ho-float-1">
        <div class="ho-float-card">
            <div class="ho-float-icon green"><i class="bi bi-shield-check-fill"></i></div>
            <div>
                <div class="ho-float-val">{{ stats.approved }}+</div>
                <div class="ho-float-lbl">Phòng xác thực</div>
            </div>
        </div>
    </div>

    <div class="ho-float ho-float-2">
        <div class="ho-float-card">
            <div class="ho-float-icon orange"><i class="bi bi-fire"></i></div>
            <div>
                <div class="ho-float-val">{{ today_new is defined ? today_new : 0 }} tin mới</div>
                <div class="ho-float-lbl">Cập nhật hôm nay</div>
            </div>
        </div>
    </div>

    <div class="ho-float ho-float-3">
        <div class="ho-float-card">
            <div class="ho-float-icon blue"><i class="bi bi-people-fill"></i></div>
            <div>
                <div class="ho-float-val">{{ stats.users }}+</div>
                <div class="ho-float-lbl">Người dùng</div>
            </div>
        </div>
    </div>

    <div class="container ho-hero-content">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-9">

                {# Live badge #}
                <div class="ho-live-badge">
                    <span class="ho-live-dot"></span>
                    <span>Nền tảng tìm phòng #1 Cần Thơ</span>
                    {% if today_new is defined and today_new > 0 %}
                        <span class="ho-today-new">✨ {{ today_new }} tin mới hôm nay</span>
                    {% endif %}
                </div>

                <h1 class="ho-hero-title">
                    Tìm phòng trọ <em>ưng ý</em><br>
                    tại <span>Cần Thơ</span>
                </h1>
                <p class="ho-hero-sub">
                    Kết nối chủ trọ &amp; người thuê · Hàng trăm phòng đã xác thực<br>
                    Tìm theo tên đường, phường, quận — siêu nhanh
                </p>

                {# ── Smart Search Box ── #}
                <div class="ho-search-shell">
                    <form action="{{ route('/properties') }}" method="GET" id="heroForm">
                        <div class="ho-search-box" id="heroSearchBox">

                            {# Keyword field + autocomplete #}
                            <div class="ho-search-field" style="flex:2.2;position:relative">
                                <i class="bi bi-search ho-sf-icon"></i>
                                <div style="flex:1">
                                    <span class="ho-sf-label">Tìm kiếm</span>
                                    <input type="text" name="keyword" id="heroKeyword"
                                           placeholder="Tên đường, khu vực, nhà trọ..."
                                           autocomplete="off"
                                           value="">
                                </div>
                                <div class="ho-autocomplete" id="heroAC"></div>
                            </div>

                            <div class="ho-search-divider"></div>

                            {# Ward #}
                            <div class="ho-search-field" style="flex:1.4">
                                <i class="bi bi-geo-alt ho-sf-icon"></i>
                                <div style="flex:1">
                                    <span class="ho-sf-label">Phường / Xã</span>
                                    <select name="ward_id">
                                        <option value="">Tất cả</option>
                                        {% for w in ward_stats %}
                                            <option value="{{ w.id }}">
                                                {{ w.name }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>

                            <div class="ho-search-divider"></div>

                            {# Price range #}
                            <div class="ho-search-field" style="flex:1.3">
                                <i class="bi bi-tag ho-sf-icon"></i>
                                <div style="flex:1">
                                    <span class="ho-sf-label">Mức giá</span>
                                    <select name="price_max">
                                        <option value="">Tất cả</option>
                                        <option value="1500000">Dưới 1.5 triệu</option>
                                        <option value="2000000">Dưới 2 triệu</option>
                                        <option value="3000000">Dưới 3 triệu</option>
                                        <option value="5000000">Dưới 5 triệu</option>
                                        <option value="10000000">Dưới 10 triệu</option>
                                    </select>
                                </div>
                            </div>

                            <button type="submit" class="ho-search-btn">
                                <i class="bi bi-search"></i>Tìm ngay
                            </button>
                        </div>
                    </form>

                    {# Hot search chips #}
                    <div class="ho-hot-row">
                        <span class="ho-hot-label"><i class="bi bi-fire me-1 text-warning"></i>Tìm nhiều:</span>
                        <a href="{{ route('/properties') }}?price_max=2000000" class="ho-hot-chip">💸 Dưới 2 triệu</a>
                        <a href="{{ route('/properties') }}?keyword=đại học cần thơ" class="ho-hot-chip">🎓 Gần ĐH Cần Thơ</a>
                        <a href="{{ route('/properties') }}?keyword=gác lửng" class="ho-hot-chip">🏠 Có gác lửng</a>
                        <a href="{{ route('/properties') }}?allow_pet=1" class="ho-hot-chip">🐾 Nuôi thú cưng</a>
                        <a href="{{ route('/properties') }}?has_wifi=1" class="ho-hot-chip">📶 WiFi miễn phí</a>
                    </div>
                </div>

            </div>
        </div>
    </div>

    {# Wave bottom divider #}
    <div class="ho-hero-wave">
        <svg viewBox="0 0 1440 88" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path d="M0,56 C360,100 1080,10 1440,56 L1440,88 L0,88 Z" fill="#ffffff"/>
        </svg>
    </div>
</section>

{# ══════════════════════════════════════════════════════════
   SECTION 2 — STATS COUNTER
══════════════════════════════════════════════════════════ #}
<div class="ho-stats-row ho-reveal">
    <div class="container">
        <div class="row g-0">
            <div class="col-6 col-md-3">
                <div class="ho-stat-cell">
                    <div class="ho-stat-icon-box orange"><i class="bi bi-house-fill"></i></div>
                    <div class="ho-stat-num" data-target="{{ stats.approved }}">0</div>
                    <div class="ho-stat-lbl">Phòng đã xác thực</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="ho-stat-cell">
                    <div class="ho-stat-icon-box blue"><i class="bi bi-people-fill"></i></div>
                    <div class="ho-stat-num" data-target="{{ stats.users }}">0</div>
                    <div class="ho-stat-lbl">Người dùng tin tưởng</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="ho-stat-cell">
                    <div class="ho-stat-icon-box green"><i class="bi bi-geo-alt-fill"></i></div>
                    <div class="ho-stat-num" data-target="{{ ward_stats|length }}">0</div>
                    <div class="ho-stat-lbl">Phường / Xã bao phủ</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="ho-stat-cell">
                    <div class="ho-stat-icon-box amber"><i class="bi bi-star-fill"></i></div>
                    <div class="ho-stat-num" data-target-float="4.8">0</div>
                    <div class="ho-stat-lbl">Đánh giá trung bình</div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ══════════════════════════════════════════════════════════
   SECTION 3 — WARD CAROUSEL (Netflix-style)
══════════════════════════════════════════════════════════ #}
{% set area_list = ward_stats is defined and ward_stats is not empty ? ward_stats : [] %}
{% if area_list is not empty %}
<section class="py-5" style="background:#fff">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4">
            <div>
                <div class="ho-sec-eyebrow"><i class="bi bi-geo-alt-fill"></i> Khu vực</div>
                <h2 class="ho-sec-title mb-1">Khám phá theo Phường / Xã</h2>
                <p class="ho-sec-sub mb-0">{{ area_list|length }} phường/xã · Sắp xếp theo mức độ quan tâm</p>
            </div>
            <a href="{{ route('/properties') }}" class="btn btn-outline-primary fw-700 rounded-pill">
                Xem tất cả <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>

        {# District → background image (uploads/districts/) #}
        {% set _dist_imgs = {
            'Ninh Kiều':  'ninh-kieu.jpg',
            'Cái Răng':   'cai-rang.jpg',
            'Thốt Nốt':   'thot-not.jpg',
            'Ô Môn':      'o-mon.jpg',
            'Bình Thủy':  'binh-thuy.jpg',
            'Phong Điền': 'phong-dien.jpg'
        } %}
        {# District → gradient fallback (24 districts) #}
        {% set _dist_grads = {
            'Ninh Kiều':     'linear-gradient(145deg,#f97316,#dc2626)',
            'Bình Thủy':     'linear-gradient(145deg,#3b82f6,#1d4ed8)',
            'Cái Răng':      'linear-gradient(145deg,#14b8a6,#0f766e)',
            'Ô Môn':         'linear-gradient(145deg,#8b5cf6,#6d28d9)',
            'Thốt Nốt':      'linear-gradient(145deg,#f59e0b,#b45309)',
            'Phong Điền':    'linear-gradient(145deg,#10b981,#047857)',
            'Cờ Đỏ':         'linear-gradient(145deg,#ef4444,#be123c)',
            'Thới Lai':      'linear-gradient(145deg,#6366f1,#4338ca)',
            'Vĩnh Thạnh':    'linear-gradient(145deg,#0ea5e9,#0369a1)',
            'Vị Thanh':      'linear-gradient(145deg,#22c55e,#15803d)',
            'Ngã Bảy':       'linear-gradient(145deg,#f43f5e,#9f1239)',
            'Long Mỹ':       'linear-gradient(145deg,#a855f7,#7e22ce)',
            'Châu Thành':    'linear-gradient(145deg,#fb923c,#c2410c)',
            'Phụng Hiệp':    'linear-gradient(145deg,#2dd4bf,#0f766e)',
            'Sóc Trăng':     'linear-gradient(145deg,#e879f9,#86198f)',
            'Ngã Năm':       'linear-gradient(145deg,#facc15,#a16207)',
            'Vĩnh Châu':     'linear-gradient(145deg,#38bdf8,#0369a1)',
            'Mỹ Xuyên':      'linear-gradient(145deg,#4ade80,#166534)',
            'Long Phú':      'linear-gradient(145deg,#f87171,#b91c1c)',
            'Kế Sách':       'linear-gradient(145deg,#818cf8,#3730a3)',
            'Mỹ Tú':         'linear-gradient(145deg,#34d399,#065f46)',
            'Trần Đề':       'linear-gradient(145deg,#fb7185,#9f1239)',
            'Cù Lao Dung':   'linear-gradient(145deg,#60a5fa,#1e3a8a)'
        } %}
        {% set _fallback_grads = [
            'linear-gradient(145deg,#f97316,#dc2626)',
            'linear-gradient(145deg,#10b981,#047857)',
            'linear-gradient(145deg,#3b82f6,#1d4ed8)',
            'linear-gradient(145deg,#8b5cf6,#6d28d9)',
            'linear-gradient(145deg,#14b8a6,#0f766e)',
            'linear-gradient(145deg,#f59e0b,#b45309)'
        ] %}

        {# Netflix carousel wrapper #}
        <div class="ho-ward-wrap" id="hoWardWrap">

            {# Prev / Next arrows #}
            <button class="ho-ward-arrow ho-ward-prev" id="hoWardPrev" aria-label="Trước">
                <i class="bi bi-chevron-left"></i>
            </button>
            <button class="ho-ward-arrow ho-ward-next" id="hoWardNext" aria-label="Tiếp theo">
                <i class="bi bi-chevron-right"></i>
            </button>

            {# Scrollable track #}
            <div class="ho-ward-track" id="hoWardTrack">
                {% for i, area in area_list %}
                    {% set _img  = _dist_imgs[area.district_name]  ?? null %}
                    {% set _grad = _dist_grads[area.district_name] ?? _fallback_grads[i % 6] %}
                    <a href="{{ route('/properties') }}?ward_id={{ area.id }}&district_id={{ area.district_id }}"
                       class="ho-area-card">
                        {% if _img %}
                            <div class="ho-area-bg"
                                 style="background-image:url('{{ upload_url }}districts/{{ _img }}');background-size:cover;background-position:center;"></div>
                        {% else %}
                            <div class="ho-area-bg" style="background:{{ _grad }}"></div>
                        {% endif %}
                        <div class="ho-area-overlay"></div>
                        <div class="ho-area-body">
                            <div class="ho-area-name">{{ area.name }}</div>
                            <div class="ho-area-district">{{ area.district_name }}</div>
                            <div class="ho-area-count">
                                <i class="bi bi-house-fill"></i>
                                {{ area.listing_count ?? 0 }} BĐS
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>

        </div>
    </div>
</section>
{% endif %}

{# ══════════════════════════════════════════════════════════
   SECTION 4 — FEATURED PROPERTY LISTINGS
══════════════════════════════════════════════════════════ #}
<section class="py-5" style="background:var(--color-bg,#f8f8f6)">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4">
            <div>
                <div class="ho-sec-eyebrow"><i class="bi bi-lightning-charge-fill"></i> Nổi bật</div>
                <h2 class="ho-sec-title mb-1">BĐS cho thuê nổi bật hôm nay</h2>
                <p class="ho-sec-sub mb-0">Các căn phòng chất lượng, giá tốt được cập nhật mới nhất</p>
            </div>
            <a href="{{ route('/properties') }}" class="btn btn-outline-primary fw-700 rounded-pill">
                Xem tất cả <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>

        {# Filter tabs #}
        <div class="ho-feat-tabs">
            <button class="ho-feat-tab active" data-type="">Tất cả</button>
            <button class="ho-feat-tab" data-type="boarding_house">🏠 Nhà trọ</button>
            <button class="ho-feat-tab" data-type="dormitory">🏫 KTX</button>
            <button class="ho-feat-tab" data-type="homestay">🏡 Homestay</button>
            <button class="ho-feat-tab" data-type="mini_house">🛋️ Căn hộ Mini</button>
            <button class="ho-feat-tab" data-type="full_house">🏘️ Nhà nguyên căn</button>
        </div>

        {% set type_labels = {
            'boarding_house': 'Nhà trọ',
            'dormitory':      'KTX',
            'homestay':       'Homestay',
            'mini_house':     'Căn hộ Mini',
            'full_house':     'Nhà nguyên căn'
        } %}

        {% if featured is empty %}
            <div class="text-center py-5 text-muted">
                <i class="bi bi-building fs-1 d-block mb-3 opacity-25"></i>
                <h5>Chưa có BĐS nổi bật</h5>
                <p class="small">Hãy quay lại sau khi có danh sách mới.</p>
            </div>
        {% else %}
            <div class="row g-3" id="featGrid">
                {% for block in featured %}
                    {% set is_composite = block.type in ['boarding_house','dormitory','homestay'] %}
                    <div class="col-sm-6 col-lg-4 col-xl-3 feat-item"
                         data-type="{{ block.type }}">
                        <a href="{{ route('/properties/' ~ block.id) }}" class="ho-fp-card">

                            {# Image section #}
                            <div class="ho-fp-img">
                                {# Placeholder always present (shows when image missing or fails to load) #}
                                <div class="ho-fp-noimg">
                                    <i class="bi bi-building-fill"></i>
                                </div>
                                {# Image overlaid above placeholder (z-index:1 covers it when loaded) #}
                                {% if block.primary_image %}
                                    <img src="{{ upload_url ~ block.primary_image }}"
                                         alt="{{ block.name }}"
                                         onload="this.style.opacity='1'"
                                         onerror="this.style.display='none'">
                                {% endif %}
                                <div class="ho-fp-img-grad"></div>

                                {# Badges — HOT / NEW #}
                                <div class="ho-fp-badges">
                                    {% if block.is_hot is defined and block.is_hot %}
                                        <span class="ho-badge-tag ho-badge-hot">🔥 HOT</span>
                                    {% endif %}
                                    {% if block.is_new is defined and block.is_new %}
                                        <span class="ho-badge-tag ho-badge-new">✨ NEW</span>
                                    {% endif %}
                                </div>

                                <span class="ho-type-badge">{{ type_labels[block.type] ?? block.type }}</span>

                                {# Price overlay #}
                                <div class="ho-fp-img-price">
                                    {% if is_composite and block.min_display_price %}
                                        <div class="ho-fp-price-big">{{ block.min_display_price|money }}</div>
                                        {% if block.max_display_price %}
                                            <div class="ho-fp-price-unit">~{{ block.max_display_price|money }}/tháng</div>
                                        {% else %}
                                            <div class="ho-fp-price-unit">/tháng</div>
                                        {% endif %}
                                    {% elseif not is_composite and block.price %}
                                        <div class="ho-fp-price-big">{{ block.price|money }}</div>
                                        <div class="ho-fp-price-unit">/tháng</div>
                                    {% endif %}
                                </div>

                                {# Hover action buttons #}
                                <div class="ho-fp-actions">
                                    {% if auth %}
                                    <button class="ho-fp-act-btn love" type="button"
                                            onclick="event.preventDefault();event.stopPropagation();"
                                            title="Lưu yêu thích">
                                        <i class="bi bi-heart"></i> Lưu
                                    </button>
                                    {% endif %}
                                    <a class="ho-fp-act-btn call"
                                       href="{{ route('/properties/' ~ block.id) }}#lien-he"
                                       onclick="event.stopPropagation()">
                                        <i class="bi bi-telephone-fill"></i> Liên hệ
                                    </a>
                                </div>
                            </div>

                            {# Card body #}
                            <div class="ho-fp-body">
                                <div class="ho-fp-title">{{ block.name }}</div>
                                <div class="ho-fp-loc">
                                    <i class="bi bi-geo-alt-fill"></i>
                                    {{ block.district_name ?? (block.address ? block.address|slice(0,32) : '') }}
                                </div>

                                {# Amenity pills #}
                                {% if block.has_wifi or block.has_ac or block.has_parking or block.allow_pet %}
                                <div class="ho-fp-pills">
                                    {% if block.has_wifi %}<span class="ho-fp-pill"><i class="bi bi-wifi"></i> WiFi</span>{% endif %}
                                    {% if block.has_ac %}<span class="ho-fp-pill"><i class="bi bi-snow2"></i> AC</span>{% endif %}
                                    {% if block.has_parking %}<span class="ho-fp-pill"><i class="bi bi-car-front"></i> Xe</span>{% endif %}
                                    {% if block.allow_pet %}<span class="ho-fp-pill">🐾 Thú cưng</span>{% endif %}
                                </div>
                                {% endif %}

                                {# Footer meta #}
                                <div class="ho-fp-foot">
                                    <span class="ho-fp-views">
                                        {% if is_composite %}
                                            <i class="bi bi-door-closed"></i> {{ block.room_count|default(0) }} phòng
                                        {% elseif block.area %}
                                            <i class="bi bi-aspect-ratio"></i> {{ block.area }}m²
                                        {% endif %}
                                    </span>
                                    <span>
                                        <i class="bi bi-clock"></i>
                                        {{ block.created_at|date('d/m/Y') }}
                                    </span>
                                </div>
                            </div>

                        </a>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

{# ══════════════════════════════════════════════════════════
   SECTION 5 — FEATURED LANDLORDS
══════════════════════════════════════════════════════════ #}
{% if top_landlords is defined and top_landlords is not empty %}
<section class="py-5" style="background:#fff">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4 ho-reveal">
            <div>
                <div class="ho-sec-eyebrow"><i class="bi bi-person-check-fill"></i> Chủ trọ</div>
                <h2 class="ho-sec-title mb-1">Chủ trọ uy tín</h2>
                <p class="ho-sec-sub mb-0">Những chủ trọ nhiều listing và đánh giá tốt nhất</p>
            </div>
        </div>
        <div class="ho-lnd-scroll ho-reveal ho-reveal-delay-1">
            {% for i, landlord in top_landlords %}
                <a href="{{ route('/properties') }}?landlord_id={{ landlord.id }}" class="ho-lnd-card" style="text-decoration:none;color:inherit;">
                    <div class="ho-lnd-avatar ho-av-{{ i % 6 }}">
                        {% if landlord.avatar %}
                            <img src="{{ upload_url ~ landlord.avatar }}" alt="{{ landlord.name }}">
                        {% else %}
                            {{ landlord.name|slice(0,1)|upper }}
                        {% endif %}
                    </div>
                    <div class="ho-lnd-name">{{ landlord.name }}</div>
                    <div class="ho-lnd-count">
                        <i class="bi bi-building me-1"></i>{{ landlord.listing_count }} BĐS
                    </div>
                    <div class="ho-lnd-stars">
                        {% for s in range(1, 5) %}
                            {% if s <= landlord.avg_rating|round(0, 'floor') %}
                                <i class="bi bi-star-fill"></i>
                            {% else %}
                                <i class="bi bi-star"></i>
                            {% endif %}
                        {% endfor %}
                        <small class="ms-1 text-muted">{{ landlord.avg_rating ? landlord.avg_rating|number_format(1) : '—' }}</small>
                    </div>
                    <div class="ho-lnd-see"><i class="bi bi-arrow-right me-1"></i>Xem BĐS</div>
                </a>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ══════════════════════════════════════════════════════════
   SECTION 6 — BANNER CAROUSEL
══════════════════════════════════════════════════════════ #}
{% if banners is not empty %}
<section class="py-3" style="background:var(--color-bg,#f8f8f6)">
    <div class="container">
        <div id="homeBannerCarousel" class="carousel slide carousel-fade"
             data-bs-ride="carousel" data-bs-interval="4500"
             style="border-radius:18px;overflow:hidden;box-shadow:0 6px 24px rgba(0,0,0,.10);">
            <div class="carousel-indicators">
                {% for banner in banners %}
                    <button type="button" data-bs-target="#homeBannerCarousel"
                            data-bs-slide-to="{{ loop.index0 }}"
                            class="{{ loop.first ? 'active' : '' }}"></button>
                {% endfor %}
            </div>
            <div class="carousel-inner">
                {% for banner in banners %}
