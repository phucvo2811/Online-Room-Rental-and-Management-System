{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
'use strict';

/* ── 1. Featured property tab filter ─────────────────────── */
var tabs  = document.querySelectorAll('.ho-feat-tab');
var items = document.querySelectorAll('.feat-item');
tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
        var type = this.dataset.type;
        tabs.forEach(function(t) { t.classList.remove('active'); });
        this.classList.add('active');
        items.forEach(function(item) {
            item.style.display = (!type || item.dataset.type === type) ? '' : 'none';
        });
    });
});

/* ── 2. Smart search autocomplete ────────────────────────── */
var suggestions = [
    {% for w in ward_stats %}
    { label: "{{ w.name|e('js') }}", type: 'ward', id: "{{ w.id }}" },
    {% endfor %}
    { label: 'Đại học Cần Thơ', type: 'keyword' },
    { label: 'Bệnh viện Đa khoa',  type: 'keyword' },
    { label: 'Có gác lửng',  type: 'keyword' },
    { label: 'Full nội thất', type: 'keyword' },
    { label: 'Gần chợ',      type: 'keyword' }
];

var kwInput = document.getElementById('heroKeyword');
var acPanel = document.getElementById('heroAC');
var wardSel = document.querySelector('[name="ward_id"]');

function buildSuggest(val) {
    var q = val.trim().toLowerCase();
    if (!q || q.length < 1) { acPanel.classList.remove('open'); return; }

    var matched = suggestions.filter(function(s) {
        return s.label.toLowerCase().indexOf(q) !== -1;
    }).slice(0, 6);

    if (!matched.length) { acPanel.classList.remove('open'); return; }

    var html = matched.map(function(s) {
        var icon = s.type === 'ward' ? 'bi-geo-alt-fill' : 'bi-search';
        return '<div class="ho-ac-item" data-val="' + s.label + '" data-ward="' + (s.id || '') + '">' +
               '<i class="bi ' + icon + '"></i> ' + s.label + '</div>';
    }).join('');
    acPanel.innerHTML = html;
    acPanel.classList.add('open');

    acPanel.querySelectorAll('.ho-ac-item').forEach(function(item) {
        item.addEventListener('mousedown', function(e) {
            e.preventDefault();
            kwInput.value = this.dataset.val;
            if (this.dataset.ward && wardSel) {
                wardSel.value = this.dataset.ward;
            }
            acPanel.classList.remove('open');
        });
    });
}

if (kwInput) {
    kwInput.addEventListener('input',  function() { buildSuggest(this.value); });
    kwInput.addEventListener('focus',  function() { buildSuggest(this.value); });
    document.addEventListener('click', function(e) {
        if (!e.target.closest('#heroSearchBox')) acPanel.classList.remove('open');
    });
}

/* ── 3. Count-up animation ───────────────────────────────── */
function easeOut(t) { return 1 - Math.pow(1 - t, 4); }

function runCountUp(el, target, isFloat, duration) {
    var start = performance.now();
    (function tick(now) {
        var progress = Math.min((now - start) / duration, 1);
        var val = isFloat
            ? (easeOut(progress) * target).toFixed(1)
            : Math.round(easeOut(progress) * target);
        el.textContent = val + (isFloat ? '' : '+');
        if (progress < 1) requestAnimationFrame(tick);
    })(performance.now());
}

var countersStarted = false;
var statsRow = document.querySelector('.ho-stats-row');
if (statsRow && 'IntersectionObserver' in window) {
    var statsObs = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting && !countersStarted) {
            countersStarted = true;
            document.querySelectorAll('.ho-stat-num').forEach(function(el) {
                var target = parseFloat(el.dataset.target || el.dataset.targetFloat || 0);
                var isFloat = !!el.dataset.targetFloat;
                setTimeout(function() { runCountUp(el, target, isFloat, 1800); }, 100);
            });
        }
    }, { threshold: 0 });
    statsObs.observe(statsRow);
}

/* ── 4. Scroll reveal ────────────────────────────────────── */
if ('IntersectionObserver' in window) {
    var revealObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
            if (e.isIntersecting) e.target.classList.add('visible');
        });
    }, { threshold: 0, rootMargin: '0px 0px -20px 0px' });
    document.querySelectorAll('.ho-reveal').forEach(function(el) {
        revealObs.observe(el);
    });
}

/* ── 5. Leaflet mini map ─────────────────────────────────── */
var mapEl = document.getElementById('hoMapCanvas');
if (mapEl && typeof L !== 'undefined') {
    var map = L.map('hoMapCanvas', {
        center: [10.0307, 105.7769],
        zoom: 12,
        zoomControl: true,
        scrollWheelZoom: false,
        attributionControl: false
    });

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 18
    }).addTo(map);

    /* Custom orange pin icon */
    var pinIcon = L.divIcon({
        html: '<div style="width:14px;height:14px;border-radius:50%;background:#f97316;border:2.5px solid #fff;box-shadow:0 2px 8px rgba(249,115,22,.5)"></div>',
        className: '',
        iconSize: [14, 14],
        iconAnchor: [7, 7]
    });

    var pins = [
        { lat: 10.0342, lng: 105.7707, name: 'Ninh Kiều' },
        { lat: 9.9984,  lng: 105.7744, name: 'Cái Răng' },
        { lat: 10.0628, lng: 105.7282, name: 'Bình Thủy' },
        { lat: 10.1396, lng: 105.6817, name: 'Ô Môn' },
        { lat: 10.2540, lng: 105.5887, name: 'Thốt Nốt' }
    ];

    pins.forEach(function(p) {
        L.marker([p.lat, p.lng], { icon: pinIcon })
            .addTo(map)
            .bindPopup('<strong>' + p.name + '</strong><br><small>Có phòng cho thuê</small>');
    });
}

/* ── 6. Ward carousel — Netflix-style arrow navigation ─────── */
(function() {
    var wrap    = document.getElementById('hoWardWrap');
    var track   = document.getElementById('hoWardTrack');
    var prevBtn = document.getElementById('hoWardPrev');
    var nextBtn = document.getElementById('hoWardNext');
    if (!track || !wrap || !prevBtn || !nextBtn) return;

    var GAP     = 16;
    var VISIBLE = 5;
    var current = 0;   // index of leftmost visible card
    var cards   = Array.from(track.querySelectorAll('.ho-area-card'));
    var total   = cards.length;
    var maxIdx  = Math.max(0, total - VISIBLE);
    var cardW   = 0;
    var sliding = false;

    /* ── Size cards to fill wrapper exactly VISIBLE slots ── */
    function calcSizes() {
        cardW = Math.floor((wrap.offsetWidth - (VISIBLE - 1) * GAP) / VISIBLE);
        wrap.style.setProperty('--card-w', cardW + 'px');
    }

    /* ── Translate track to index ── */
    function goTo(idx, animate) {
        if (sliding && animate) return;
        // Clamp
        idx = Math.max(0, Math.min(idx, maxIdx));
        if (idx === current && animate) return;
        current = idx;

        var offset = current * (cardW + GAP);
        if (animate) {
            sliding = true;
            track.style.transition = 'transform .52s cubic-bezier(.4,0,.2,1)';
            track.addEventListener('transitionend', function onDone() {
                track.removeEventListener('transitionend', onDone);
                sliding = false;
            });
        } else {
            track.style.transition = 'none';
        }
        track.style.transform = 'translateX(' + (-offset) + 'px)';
        updateControls();
    }

    /* ── Prev / Next buttons ── */
    nextBtn.addEventListener('click', function() { goTo(current + 1, true); });
    prevBtn.addEventListener('click', function() { goTo(current - 1, true); });

    /* ── Keyboard arrow support ── */
    wrap.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowRight') { e.preventDefault(); goTo(current + 1, true); }
        if (e.key === 'ArrowLeft')  { e.preventDefault(); goTo(current - 1, true); }
    });

    /* ── Touch / swipe ── */
    var tX0 = 0;
    track.addEventListener('touchstart', function(e) {
        tX0 = e.touches[0].clientX;
    }, { passive: true });
    track.addEventListener('touchend', function(e) {
        var dx = e.changedTouches[0].clientX - tX0;
        if (Math.abs(dx) > 44) goTo(current + (dx < 0 ? 1 : -1), true);
    }, { passive: true });

    /* ── Update arrow state ── */
    function updateControls() {
        prevBtn.disabled = current <= 0;
        nextBtn.disabled = current >= maxIdx;
    }

    /* ── Init ── */
    calcSizes();
    goTo(0, false);
    updateControls();

    /* ── Recalc on resize ── */
    var resizeTimer;
    window.addEventListener('resize', function() {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function() {
            /* Recalculate VISIBLE based on viewport */
            VISIBLE = window.innerWidth < 640 ? 2 : window.innerWidth < 900 ? 3 : 5;
            maxIdx  = Math.max(0, total - VISIBLE);
            current = Math.min(current, maxIdx);
            calcSizes();
            goTo(current, false);
            updateControls();
        }, 120);
    });
})();

})();
</script>
{% endblock %}
