{% extends 'layouts/base.twig' %}
{% block title %}{{ mode == 'create' ? 'Đăng tin phòng trọ' : 'Chỉnh sửa tin đăng' }}{% endblock %}

{% block content %}
<div class="bg-light py-3 border-bottom">
    <div class="container">
        <ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item"><a href="{{ route('/') }}">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="{{ route('/my-rooms') }}">Phòng của tôi</a></li>
            <li class="breadcrumb-item active">{{ mode == 'create' ? 'Đăng tin mới' : 'Chỉnh sửa' }}</li>
        </ol>
    </div>
</div>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            <div class="post-wizard">

                <div class="wizard-header">
                    <h4 class="text-white fw-800 mb-1">
                        <i class="bi bi-plus-circle me-2"></i>
                        {{ mode == 'create' ? 'Đăng tin phòng trọ mới' : 'Chỉnh sửa tin đăng' }}
                    </h4>
                    <p class="text-white-50 small mb-4">Điền đầy đủ để tin được duyệt nhanh hơn</p>
                    <div class="wizard-steps">
                        {% for i, label in ['Cơ bản','Tiện ích','Chi phí','Hình ảnh'] %}
                            <div class="wizard-step {{ i == 0 ? 'active' : '' }}" id="stepNav{{ i + 1 }}">
                                <div class="step-circle">{{ i + 1 }}</div>
                                <div class="step-label">{{ label }}</div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div class="wizard-body">
                    <form action="{{ mode == 'create' ? route('/rooms/create') : route('/rooms/' ~ room.id ~ '/edit') }}"
                          method="POST" enctype="multipart/form-data" id="roomForm">
                        <input type="hidden" name="_csrf" value="{{ csrf }}">
                        {% if mode == 'edit' %}
                            <input type="hidden" name="room_number" value="{{ room.room_number ?? '' }}">
                        {% endif %}

                        {# STEP 1 #}
                        <div id="step1">
                            <div class="form-section">
                                <div class="form-section-title">
                                    <i class="bi bi-info-circle me-2"></i>Thông tin cơ bản
                                </div>
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label class="form-label fw-600">Tiêu đề <span class="text-danger">*</span></label>
                                        <input type="text" name="title"
                                            class="form-control {{ errors.title is defined ? 'is-invalid' : '' }}"
                                            placeholder="VD: Phòng trọ cao cấp Nguyễn Văn Cừ, full nội thất"
                                            value="{{ room.title ?? '' }}"
                                            id="titleInput">
                                        {% if errors.title is defined %}
                                            <div class="invalid-feedback">{{ errors.title }}</div>
                                        {% endif %}
                                        {% if room.block_id is not defined or not room.block_id %}
                                        <div class="form-text" id="titleHint">Tối thiểu 10 ký tự</div>
                                        {% endif %}
                                        <div class="form-text alert alert-info alert-sm mt-2" id="titleBoardingHousHint" style="display:none;">
                                            <i class="bi bi-info-circle me-1"></i>Với phòng trọ/ký túc xá, tên chỉ cần là số phòng (không cần tiêu đề dài)
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label fw-600">Loại phòng</label>
                                        <select name="room_type" class="form-select">
                                            {% for key, label in room_types %}
                                                <option value="{{ key }}"
                                                    {{ (room.room_type ?? 'phong_tro') == key ? 'selected' : '' }}>
                                                    {{ label }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-600">Loại phòng (trừ room_types)</label>
                                        <select name="room_type_id" class="form-select">
                                            <option value="">Không chọn</option>
                                            {% for t in room_types_list ?? [] %}
                                                <option value="{{ t.id }}" {{ (room.room_type_id ?? '') == t.id ? 'selected' : '' }}>{{ t.name }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    <div class="col-md-4" id="houseBlockSection">
                                        {% if mode == 'edit' and room.block_id %}
                                        <label class="form-label fw-600">Thuộc nhà trọ / KTX</label>
                                        <input type="hidden" name="block_id" value="{{ room.block_id }}">
                                        <div class="form-control-plaintext text-muted">
                                            <i class="bi bi-building me-1"></i>
                                            {% for b in room_blocks ?? [] %}{% if b.id == room.block_id %}{{ b.name }}{% endif %}{% endfor %}
                                            <small class="d-block text-secondary">Liên kết cố định từ khi tạo phòng</small>
                                        </div>
                                        {% else %}
                                        <label class="form-label fw-600">Thuộc nhà trọ/ký túc xá (tuỳ chọn)</label>
                                        <select name="block_id" class="form-select {{ errors.block_id is defined ? 'is-invalid' : '' }}">
                                            <option value="">Không liên kết</option>
                                            {% for b in room_blocks ?? [] %}
                                                <option value="{{ b.id }}" data-block-type="{{ b.type }}" {{ (room.block_id ?? '') == b.id ? 'selected' : '' }}>{{ b.name }} ({{ b.room_count }} phòng)</option>
                                            {% endfor %}
                                        </select>
                                        {% if errors.block_id is defined %}
                                            <div class="invalid-feedback">{{ errors.block_id }}</div>
                                        {% endif %}
                                        <div class="form-text text-muted">Chỉ cần chọn nếu bạn muốn ghép phòng vào nhà trọ/ký túc xá.</div>
                                        {% endif %}
                                    </div>
                                    <div class="col-md-4" id="houseBlockBlockedInfo" style="display:none;">
                                        <label class="form-label fw-600">Thuộc nhà trọ</label>
                                        <div class="form-control-plaintext text-muted">Tuỳ chọn liên kết với Nhà trọ / KTX / Homestay.</div>
                                    </div>

                                    <div class="col-md-3">
                                        <label class="form-label fw-600">Giá thuê/tháng <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <input type="number" name="price"
                                                class="form-control {{ errors.price is defined ? 'is-invalid' : '' }}"
                                                placeholder="2500000" min="0" value="{{ room.price ?? '' }}">
                                            <span class="input-group-text">đ</span>
                                        </div>
                                        {% if errors.price is defined %}
                                            <div class="text-danger small">{{ errors.price }}</div>
                                        {% endif %}
                                    </div>

                                    <div class="col-md-3">
                                        <label class="form-label fw-600">Diện tích <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <input type="number" name="area"
                                                class="form-control {{ errors.area is defined ? 'is-invalid' : '' }}"
                                                placeholder="20" min="1" step="0.5" value="{{ room.area ?? '' }}">
                                            <span class="input-group-text">m²</span>
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label fw-600">Địa chỉ <span class="text-danger">*</span></label>
                                        <input type="text" name="address"
                                            class="form-control {{ errors.address is defined ? 'is-invalid' : '' }}"
                                            placeholder="VD: 123 Nguyễn Văn Cừ, P. An Bình, Q. Ninh Kiều"
                                            value="{{ room.address ?? '' }}">
                                        {% if errors.address is defined %}
                                            <div class="invalid-feedback">{{ errors.address }}</div>
                                        {% endif %}
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label fw-600">Quận / Huyện</label>
                                        <select name="district_id" class="form-select" id="districtSel"
                                            onchange="loadWards(this.value,'wardSel')">
                                            <option value="">Chọn quận</option>
                                            {% for d in districts %}
                                                <option value="{{ d.id }}"
                                                    {{ (room.district_id ?? '') == d.id ? 'selected' : '' }}>
                                                    {{ d.name }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label fw-600">Phường / Xã</label>
                                        <select name="ward_id" class="form-select" id="wardSel"
                                            onchange="loadStreets(this.value,'streetSel')">
                                            <option value="">Chọn phường</option>
                                            {% for w in wards ?? [] %}
                                                <option value="{{ w.id }}"
                                                    {{ (room.ward_id ?? '') == w.id ? 'selected' : '' }}>
                                                    {{ w.name }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label fw-600">Đường / Phố</label>
                                        <select name="street_id" class="form-select" id="streetSel">
                                            <option value="">Chọn đường</option>
                                            {% for s in streets ?? [] %}
                                                <option value="{{ s.id }}"
                                                    {{ (room.street_id ?? '') == s.id ? 'selected' : '' }}>
                                                    {{ s.name }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>

                                    <div class="col-md-3">
                                        <label class="form-label fw-600">Số người tối đa</label>
                                        <input type="number" name="max_people" class="form-control"
                                            min="1" max="20" value="{{ room.max_people ?? 1 }}">
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label fw-600">Tầng số</label>
                                        <input type="number" name="floor" class="form-control"
                                            min="1" value="{{ room.floor ?? 1 }}">
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label fw-600">Tổng số tầng</label>
                                        <input type="number" name="total_floors" class="form-control"
                                            min="1" value="{{ room.total_floors ?? 1 }}">
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label fw-600">Tiền cọc (tháng)</label>
                                        <input type="number" name="deposit_months" class="form-control"
                                            min="0" max="12" value="{{ room.deposit_months ?? 1 }}">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-600">Ngày có thể vào ở</label>
                                        <input type="date" name="available_from" class="form-control"
                                            value="{{ room.available_from ?? 'now'|date('Y-m-d') }}">
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label fw-600">Mô tả chi tiết</label>
                                        <textarea name="description" class="form-control" rows="5"
                                            placeholder="Mô tả phòng, vị trí, tiện ích xung quanh, quy định...">{{ room.description ?? '' }}</textarea>
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-end mt-3">
                                <button type="button" class="btn btn-primary px-5" onclick="goStep(2)">
                                    Tiếp theo <i class="bi bi-arrow-right ms-2"></i>
                                </button>
                            </div>
                        </div>

                        {# STEP 2 #}
                        <div id="step2" style="display:none">
                            <div class="form-section">
                                <div class="form-section-title">
                                    <i class="bi bi-stars me-2"></i>Tiện ích & Chính sách
                                </div>
                                {% set amenities = [
                                    ['has_wifi',            'bi-wifi',      'WiFi miễn phí'],
                                    ['has_ac',              'bi-snow2',     'Điều hòa'],
                                    ['has_parking',         'bi-car-front', 'Gửi xe'],
                                    ['has_kitchen',         'bi-cup-hot',   'Bếp nấu'],
                                    ['has_washing_machine', 'bi-recycle',   'Máy giặt'],
                                    ['has_fridge',          'bi-box',       'Tủ lạnh'],
                                    ['has_private_bath',    'bi-droplet',   'WC riêng'],
                                    ['allow_pet',           'bi-heart',     'Nuôi thú cưng'],
                                    ['allow_cooking',       'bi-fire',      'Nấu ăn']
                                ] %}
                                <div class="amenity-picker">
                                    {% for item in amenities %}
                                        <label class="amenity-pick-item {{ room[item[0]] ?? false ? 'checked' : '' }}">
                                            <input type="checkbox" name="{{ item[0] }}" value="1"
                                                {{ room[item[0]] ?? false ? 'checked' : '' }}
                                                onchange="this.closest('label').classList.toggle('checked',this.checked)">
                                            <i class="bi {{ item[1] }}"></i> {{ item[2] }}
                                        </label>
                                    {% endfor %}
                                </div>
                            </div>

                            <div class="form-section">
                                <div class="form-section-title">
                                    <i class="bi bi-person-lines-fill me-2"></i>Thông tin liên hệ
                                </div>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-600">Tên liên hệ <span class="text-danger">*</span></label>
                                        <input type="text" name="contact_name" class="form-control"
                                            placeholder="Nguyễn Văn A"
                                            value="{{ room.contact_name ?? auth.name ?? '' }}">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-600">Số điện thoại <span class="text-danger">*</span></label>
                                        <input type="tel" name="contact_phone"
                                            class="form-control {{ errors.contact_phone is defined ? 'is-invalid' : '' }}"
                                            placeholder="0901234567"
                                            value="{{ room.contact_phone ?? '' }}">
                                        {% if errors.contact_phone is defined %}
                                            <div class="invalid-feedback">{{ errors.contact_phone }}</div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between mt-3">
                                <button type="button" class="btn btn-outline-secondary px-4" onclick="goStep(1)">
                                    <i class="bi bi-arrow-left me-2"></i>Quay lại
                                </button>
                                <button type="button" class="btn btn-primary px-5" onclick="goStep(3)">
                                    Tiếp theo <i class="bi bi-arrow-right ms-2"></i>
                                </button>
                            </div>
                        </div>

                        {# STEP 3 #}
                        <div id="step3" style="display:none">
                            <div class="form-section">
                                <div class="form-section-title">
                                    <i class="bi bi-receipt me-2"></i>Chi phí dịch vụ
                                </div>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="form-label fw-600">Giá điện (đ/kWh)</label>
                                        <input type="number" name="electric_price" class="form-control"
                                            min="0" placeholder="3500" value="{{ room.electric_price ?? '' }}">
                                        <div class="form-text">Để trống nếu đã bao gồm</div>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-600">Giá nước (đ/m³)</label>
                                        <input type="number" name="water_price" class="form-control"
                                            min="0" placeholder="15000" value="{{ room.water_price ?? '' }}">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-600">Internet (đ/tháng)</label>
                                        <input type="number" name="internet_price" class="form-control"
                                            min="0" placeholder="0" value="{{ room.internet_price ?? '' }}">
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between mt-3">
                                <button type="button" class="btn btn-outline-secondary px-4" onclick="goStep(2)">
                                    <i class="bi bi-arrow-left me-2"></i>Quay lại
                                </button>
                                <button type="button" class="btn btn-primary px-5" onclick="goStep(4)">
                                    Tiếp theo <i class="bi bi-arrow-right ms-2"></i>
                                </button>
                            </div>
                        </div>

                        {# STEP 4 #}
                        <div id="step4" style="display:none">
                            <div class="form-section">
                                <div class="form-section-title">
                                    <i class="bi bi-images me-2"></i>Hình ảnh phòng
                                </div>
                                <div class="upload-zone" id="uploadZone"
                                     onclick="document.getElementById('imgInput').click()">
                                    <div class="text-center py-4 px-3">
                                        <div class="upload-zone-icon"><i class="bi bi-cloud-arrow-up-fill"></i></div>
                                        <h6 class="fw-700 mb-1">Kéo thả hoặc click để chọn ảnh</h6>
                                        <p class="text-muted small mb-0">Tối đa 10 ảnh &middot; Mỗi ảnh &le; 5MB &middot; JPG, PNG, WebP</p>
                                        <span class="badge bg-warning text-dark mt-2" style="font-size:.72rem;">
                                            <i class="bi bi-star-fill me-1"></i>Ảnh đầu tiên sẽ là ảnh bìa
                                        </span>
                                    </div>
                                </div>
                                <input type="file" name="images[]" id="imgInput" multiple
                                       accept="image/*" style="display:none"
                                       onchange="previewImages(this)">
                                <div class="row g-2 mt-3" id="imgPreview"></div>

                                {% if images is defined and images is not empty %}
                                    <div class="mt-4">
                                        <p class="fw-700 small mb-3"><i class="bi bi-images me-2 text-primary"></i>Ảnh hiện có — tích chọn để xoá:</p>
                                        <div class="d-flex flex-wrap gap-2">
                                            {% for img in images %}
                                                <div class="existing-img-card">
                                                    <img src="{{ upload_url ~ img.image_path }}" alt="">
                                                    {% if img.is_primary %}
                                                        <span class="existing-img-cover"><i class="bi bi-star-fill me-1"></i>Bìa</span>
                                                    {% endif %}
                                                    <label class="existing-img-del">
                                                        <input type="checkbox" name="delete_images[]" value="{{ img.id }}">
                                                        <span><i class="bi bi-trash3-fill"></i></span>
                                                    </label>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                {% endif %}
                            </div>

                            <div class="d-flex justify-content-between mt-3">
                                <button type="button" class="btn btn-outline-secondary px-4" onclick="goStep(3)">
                                    <i class="bi bi-arrow-left me-2"></i>Quay lại
                                </button>
                                <button type="submit" class="btn btn-success px-5 fw-700">
                                    <i class="bi bi-send me-2"></i>
                                    {{ mode == 'create' ? 'Đăng tin ngay' : 'Lưu thay đổi' }}
                                </button>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    function toggleHouseBlockSection() {
        var roomType = document.querySelector('select[name=room_type]').value;
        var allowed = ['boarding_house', 'dormitory', 'phong_tro', 'ky_tuc_xa', 'homestay'];
        var blockSection = document.getElementById('houseBlockSection');
        var blockedInfo = document.getElementById('houseBlockBlockedInfo');
        if (allowed.includes(roomType)) {
            blockSection.style.display = 'block';
            blockedInfo.style.display = 'none';
        } else {
            blockSection.style.display = 'none';
            blockedInfo.style.display = 'block';
        }
        updateTitleRequirements();
    }
    
    function updateTitleRequirements() {
        var blockSelect = document.querySelector('select[name=block_id]');
        var selectedBlockId = blockSelect ? blockSelect.value : null;
        var titleInput = document.getElementById('titleInput');
        var titleHint = document.getElementById('titleHint');
        var boardingHouseHint = document.getElementById('titleBoardingHousHint');
        
        // Get block type from selected option's data attribute or from room_blocks data
        var blockType = null;
        if (selectedBlockId) {
            var selectedOption = blockSelect.querySelector('option[value="' + selectedBlockId + '"]');
            if (selectedOption && selectedOption.dataset.blockType) {
                blockType = selectedOption.dataset.blockType;
            }
        }
        
        // If boarding_house or dormitory, show helpful message and relax requirements
        if (blockType === 'boarding_house' || blockType === 'dormitory') {
            titleHint.style.display = 'none';
            boardingHouseHint.style.display = 'block';
            titleInput.removeAttribute('data-minlength');
        } else {
            titleHint.style.display = 'block';
            boardingHouseHint.style.display = 'none';
            titleInput.setAttribute('data-minlength', '10');
        }
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        var roomTypeSelect = document.querySelector('select[name=room_type]');
        var blockSelect = document.querySelector('select[name=block_id]');
        
        if (roomTypeSelect) {
            roomTypeSelect.addEventListener('change', toggleHouseBlockSection);
            toggleHouseBlockSection();
        }
        
        if (blockSelect) {
            blockSelect.addEventListener('change', updateTitleRequirements);
            updateTitleRequirements();
        }
    });
</script>
{% endblock %}

{% block scripts %}
<style>
.upload-zone {
    border: 2.5px dashed #d1d5db;
    border-radius: 16px;
    cursor: pointer;
    background: linear-gradient(135deg, #fafaf9 0%, #f0f9ff 100%);
    transition: all .25s;
}
.upload-zone:hover, .upload-zone.drag-over {
    border-color: var(--primary);
    background: linear-gradient(135deg, #fff7ed 0%, #fffbf5 100%);
    box-shadow: 0 0 0 4px rgba(249,115,22,.08);
}
.upload-zone-icon {
    font-size: 2.8rem;
    background: linear-gradient(135deg, #f97316, #ea580c);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1; margin-bottom: 10px;
}
.img-preview-card {
    border-radius: 12px; overflow: hidden;
    border: 2px solid #e2e8f0; background: #fff;
    transition: all .2s; position: relative;
    box-shadow: 0 2px 8px rgba(0,0,0,.06);
}
.img-preview-card.is-cover { border-color: var(--primary); box-shadow: 0 4px 14px rgba(249,115,22,.22); }
.img-preview-img { height: 120px; overflow: hidden; position: relative; background: #f8fafc; }
.img-preview-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.img-cover-badge {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(249,115,22,.92), rgba(249,115,22,.0));
    color: #fff; font-size: .7rem; font-weight: 800;
    padding: 22px 8px 6px; text-align: center; letter-spacing: .03em;
}
.img-preview-name {
    padding: 6px 10px; font-size: .72rem; font-weight: 600;
    color: #64748b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    border-top: 1px solid #f1f5f9;
}
/* Existing images */
.existing-img-card {
    position: relative; width: 96px;
    border-radius: 10px; overflow: hidden;
    border: 2px solid #e2e8f0;
    box-shadow: 0 2px 8px rgba(0,0,0,.06);
    transition: border-color .2s;
}
.existing-img-card img {
    width: 96px; height: 72px; object-fit: cover; display: block;
}
.existing-img-cover {
    position: absolute; top: 0; left: 0; right: 0;
    background: linear-gradient(to bottom, rgba(249,115,22,.9), transparent);
    color: #fff; font-size: .65rem; font-weight: 800;
    padding: 4px 6px 12px; display: flex; align-items: center; gap: 2px;
}
.existing-img-del {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: rgba(239,68,68,.88); color: #fff;
    font-size: .7rem; text-align: center; padding: 3px;
    cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 4px;
}
.existing-img-del:has(input:checked) { background: rgba(239,68,68,1); }
.existing-img-del input { position: absolute; opacity: 0; width: 0; }
.existing-img-card:has(input:checked) { border-color: #ef4444; opacity: .7; }
</style>
<script>
const APP_URL = '{{ app_url }}';
let currentStep = 1;

function goStep(n) {
    document.getElementById('step' + currentStep).style.display = 'none';
    const prevNav = document.getElementById('stepNav' + currentStep);
    prevNav.classList.remove('active');
    if (n > currentStep) prevNav.classList.add('done');
    else prevNav.classList.remove('done');
    currentStep = n;
    document.getElementById('step' + n).style.display = 'block';
    document.getElementById('stepNav' + n).classList.add('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

function loadWards(districtId, targetId) {
    const sel = document.getElementById(targetId);
    if (!districtId) { sel.innerHTML = '<option value="">Chọn phường</option>'; return; }
    fetch(`${APP_URL}/api/wards?district_id=${districtId}`)
        .then(r => r.json())
        .then(data => {
            sel.innerHTML = '<option value="">Chọn phường</option>';
            data.forEach(w => sel.innerHTML += `<option value="${w.id}">${w.name}</option>`);
        });
}

function loadStreets(wardId, targetId) {
    const sel = document.getElementById(targetId);
    if (!wardId) { sel.innerHTML = '<option value="">Chọn đường</option>'; return; }
    fetch(`${APP_URL}/api/streets?ward_id=${wardId}`)
        .then(r => r.json())
        .then(data => {
            sel.innerHTML = '<option value="">Chọn đường</option>';
            data.forEach(s => sel.innerHTML += `<option value="${s.id}">${s.name}</option>`);
        });
}

function previewImages(input) {
    const preview = document.getElementById('imgPreview');
    preview.innerHTML = '';
    const files = [...input.files].slice(0, 10);
    files.forEach((file, i) => {
        const reader = new FileReader();
        reader.onload = e => {
            const col = document.createElement('div');
            col.className = 'col-6 col-md-4 col-lg-3';
            const name = file.name.length > 22 ? file.name.substring(0, 19) + '…' : file.name;
            col.innerHTML = `
                <div class="img-preview-card${i === 0 ? ' is-cover' : ''}">
                    <div class="img-preview-img">
                        <img src="${e.target.result}" alt="Ảnh ${i + 1}">
                        ${i === 0 ? '<div class="img-cover-badge"><i class="bi bi-star-fill me-1"></i>Ảnh bìa</div>' : ''}
                    </div>
                    <div class="img-preview-name">${name}</div>
                </div>`;
            preview.appendChild(col);
        };
        reader.readAsDataURL(file);
    });
}

const zone = document.getElementById('uploadZone');
zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
zone.addEventListener('drop', e => {
    e.preventDefault();
    zone.classList.remove('drag-over');
    document.getElementById('imgInput').files = e.dataTransfer.files;
    previewImages(document.getElementById('imgInput'));
});
</script>
{% endblock %}