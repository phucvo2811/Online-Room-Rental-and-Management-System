{% extends 'layouts/base.twig' %}
{% block title %}{{ room.title }}{% endblock %}

{% block head %}
<style>
/* ── Room Gallery ──────────────────────────────────── */
.rg-wrap { border-radius: 16px; overflow: hidden; box-shadow: 0 6px 28px rgba(0,0,0,.14); margin-bottom: 20px; background: #111; }
.rg-main {
    position: relative; height: 420px; overflow: hidden; cursor: zoom-in;
    background: #1a1a1a;
}
@media(max-width:767.98px){ .rg-main { height: 260px; } }
.rg-main img {
    width: 100%; height: 100%; object-fit: cover;
    transition: opacity .25s ease;
    display: block;
}
.rg-main img.rg-fade { opacity: 0; }
.rg-arrow {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 42px; height: 42px; border-radius: 50%;
    background: rgba(0,0,0,.55); color: #fff; border: none;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; cursor: pointer; z-index: 5;
    transition: background .2s, transform .2s;
    backdrop-filter: blur(4px); box-shadow: 0 2px 12px rgba(0,0,0,.3);
}
.rg-arrow:hover { background: rgba(0,0,0,.82); transform: translateY(-50%) scale(1.1); }
.rg-arrow-prev { left: 14px; }
.rg-arrow-next { right: 14px; }
.rg-counter {
    position: absolute; bottom: 14px; right: 14px;
    background: rgba(0,0,0,.6); color: #fff;
    font-size: .75rem; font-weight: 700; padding: 4px 12px;
    border-radius: 20px; backdrop-filter: blur(6px); z-index: 5;
    letter-spacing: .04em;
}
.rg-expand-btn {
    position: absolute; bottom: 14px; left: 14px;
    background: rgba(0,0,0,.6); color: #fff; border: none;
    font-size: .78rem; font-weight: 600; padding: 5px 13px;
    border-radius: 20px; cursor: pointer; backdrop-filter: blur(6px); z-index: 5;
    display: flex; align-items: center; gap: 6px; transition: background .2s;
}
.rg-expand-btn:hover { background: rgba(0,0,0,.85); }
.rg-no-img {
    height: 420px; display: flex; align-items: center;
    justify-content: center; flex-direction: column; gap: 12px;
    background: linear-gradient(135deg, #f3f4f6, #e9eaec); color: #9ca3af;
}
/* Thumbnail strip */
.rg-thumbs {
    display: flex; gap: 5px; padding: 8px 10px;
    background: #1a1a1a;
    overflow-x: auto; scrollbar-width: thin; scrollbar-color: #555 #1a1a1a;
}
.rg-thumbs::-webkit-scrollbar { height: 4px; }
.rg-thumbs::-webkit-scrollbar-track { background: #1a1a1a; }
.rg-thumbs::-webkit-scrollbar-thumb { background: #555; border-radius: 4px; }
.rg-thumb {
    flex-shrink: 0; width: 74px; height: 56px; border-radius: 7px;
    overflow: hidden; cursor: pointer; border: 2.5px solid transparent;
    opacity: .5; transition: all .2s; position: relative;
}
.rg-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
.rg-thumb:hover { opacity: .85; border-color: rgba(249,115,22,.7); }
.rg-thumb.active { opacity: 1; border-color: #f97316; box-shadow: 0 0 0 1px #f97316; }
/* Lightbox */
.rg-lightbox {
    display: none; position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,.96); align-items: center; justify-content: center;
    flex-direction: column; padding: 20px;
}
.rg-lightbox.open { display: flex; }
.rg-lb-close {
    position: fixed; top: 16px; right: 16px;
    background: rgba(255,255,255,.12); color: #fff; border: none;
    width: 44px; height: 44px; border-radius: 50%; font-size: 1.35rem;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    backdrop-filter: blur(6px); transition: background .2s; z-index: 2;
}
.rg-lb-close:hover { background: rgba(255,255,255,.25); }
.rg-lb-img-wrap {
    position: relative; display: flex; align-items: center; justify-content: center;
    max-width: min(92vw, 1200px); width: 100%;
}
.rg-lb-img {
    max-width: 100%; max-height: 80vh;
    object-fit: contain; border-radius: 8px;
    box-shadow: 0 0 80px rgba(0,0,0,.5);
    user-select: none;
}
.rg-lb-arrow {
    position: absolute; top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,.12); color: #fff; border: none;
    width: 48px; height: 48px; border-radius: 50%; font-size: 1.25rem;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    backdrop-filter: blur(6px); transition: background .2s; z-index: 2;
}
.rg-lb-arrow:hover { background: rgba(255,255,255,.26); }
.rg-lb-prev { left: -60px; }
.rg-lb-next { right: -60px; }
@media(max-width:767.98px) {
    .rg-lb-prev { left: 4px; } .rg-lb-next { right: 4px; }
    .rg-lb-arrow { width: 38px; height: 38px; font-size: 1rem; }
}
.rg-lb-caption {
    color: rgba(255,255,255,.6); font-size: .82rem; font-weight: 600;
    margin-top: 14px; letter-spacing: .04em;
}
</style>
{% endblock %}

{% block content %}
<div class="bg-light py-3 border-bottom">
    <div class="container">
        <ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item"><a href="{{ route('/') }}">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="{{ route('/properties') }}">Nhà trọ/KTX</a></li>
            <li class="breadcrumb-item active">{{ room.title|truncate(40) }}</li>
        </ol>
    </div>
</div>

<div class="container py-4">
    <div class="row g-4">

        {# ── LEFT ── #}
        <div class="col-lg-8">

            {# Gallery #}
            {% if images is not empty %}
            {# Build JS-safe image array for pass-through #}
            {% set imgSrcs = [] %}
            {% for img in images %}{% set imgSrcs = imgSrcs|merge([upload_url ~ img.image_path]) %}{% endfor %}

            <div class="rg-wrap">
                {# Main image #}
                <div class="rg-main" onclick="rgExpand(rgIdx)">
                    <img id="rgMainImg" src="{{ upload_url ~ images[0].image_path }}" alt="{{ room.title }}">
                    {% if images|length > 1 %}
                        <button class="rg-arrow rg-arrow-prev" type="button"
                                onclick="event.stopPropagation(); rgNav(-1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        <button class="rg-arrow rg-arrow-next" type="button"
                                onclick="event.stopPropagation(); rgNav(1)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    {% endif %}
                    <span class="rg-counter" id="rgCounter">1 / {{ images|length }}</span>
                    <button class="rg-expand-btn" type="button"
                            onclick="event.stopPropagation(); rgExpand(rgIdx)">
                        <i class="bi bi-arrows-fullscreen"></i> Xem toàn màn hình
                    </button>
                </div>
                {# Thumbnails #}
                {% if images|length > 1 %}
                <div class="rg-thumbs" id="rgThumbs">
                    {% for img in images %}
                    <div class="rg-thumb {{ loop.first ? 'active' : '' }}"
                         onclick="rgGoTo({{ loop.index0 }})">
                        <img src="{{ upload_url ~ img.image_path }}" alt="" loading="lazy">
                    </div>
                    {% endfor %}
                </div>
                {% endif %}
            </div>

            {# Lightbox #}
            <div class="rg-lightbox" id="rgLightbox" onclick="rgCloseLb()">
                <button class="rg-lb-close" type="button" onclick="event.stopPropagation(); rgCloseLb()">
                    <i class="bi bi-x-lg"></i>
                </button>
                <div class="rg-lb-img-wrap" onclick="event.stopPropagation()">
                    {% if images|length > 1 %}
                    <button class="rg-lb-arrow rg-lb-prev" type="button" onclick="rgLbNav(-1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <button class="rg-lb-arrow rg-lb-next" type="button" onclick="rgLbNav(1)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                    {% endif %}
                    <img id="rgLbImg" src="" alt="{{ room.title }}" class="rg-lb-img">
                </div>
                <div class="rg-lb-caption" id="rgLbCaption"></div>
            </div>

            {% else %}
            <div class="rg-wrap mb-4">
                <div class="rg-no-img">
                    <i class="bi bi-image" style="font-size:3rem"></i>
                    <span class="fw-600">Chưa có ảnh</span>
                </div>
            </div>
            {% endif %}

            {# Title #}
            <div class="room-detail-card">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                    <div>
                        <span class="room-type-tag mb-2">
                            <i class="bi bi-house-door"></i>
                            {{ room_types[room.room_type] ?? room.room_type }}
                        </span>
                        <div class="d-flex gap-2 align-items-start flex-wrap">
                            <h1 class="fs-4 fw-800 mb-1">{{ room.title }}</h1>
                            {% if room.is_pro %}
                                <span class="badge bg-info text-dark mt-1">PRO</span>
                            {% endif %}
                        </div>
                        <div class="d-flex align-items-center gap-3 text-muted small flex-wrap">
                            <span><i class="bi bi-geo-alt-fill text-primary me-1"></i>{{ room.address }}</span>
                            {% if room.district_name %}
                                <span><i class="bi bi-map me-1"></i>{{ room.district_name }}</span>
                            {% endif %}
                            <span><i class="bi bi-eye me-1"></i>{{ room.view_count|number_format }} lượt xem</span>
                            {% if room.avg_rating > 0 %}
                                <span class="text-warning">
                                    <i class="bi bi-star-fill me-1"></i>
                                    {{ room.avg_rating }} ({{ room.review_count }} đánh giá)
                                </span>
                            {% endif %}
                        </div>
                    </div>
                    {% if auth %}
                        <button class="btn btn-outline-{{ isFavorite ? 'danger' : 'secondary' }} btn-sm"
                            onclick="toggleFav(this, {{ room.id }})">
                            <i class="bi bi-heart{{ isFavorite ? '-fill' : '' }} me-1"></i>
                            {{ isFavorite ? 'Đã lưu' : 'Lưu' }}
                        </button>
                    {% endif %}
                </div>

                <div class="row g-3 py-3 border-top border-bottom mb-3">
                    <div class="col-6 col-md-3 text-center">
                        <div class="fw-800 fs-5 text-primary">{{ room.area }}m²</div>
                        <div class="small text-muted">Diện tích</div>
                    </div>
                    <div class="col-6 col-md-3 text-center">
                        <div class="fw-800 fs-5">{{ room.max_people }} người</div>
                        <div class="small text-muted">Tối đa</div>
                    </div>
                    <div class="col-6 col-md-3 text-center">
                        <div class="fw-800 fs-5">Tầng {{ room.floor }}</div>
                        <div class="small text-muted">/ {{ room.total_floors }} tầng</div>
                    </div>
                    <div class="col-6 col-md-3 text-center">
                        <div class="fw-800 fs-5">{{ room.deposit_months }} tháng</div>
                        <div class="small text-muted">Tiền cọc</div>
                    </div>
                </div>

                <h6 class="fw-700 mb-2"><i class="bi bi-file-text me-2 text-primary"></i>Mô tả</h6>
                <p class="text-muted">{{ room.description|nl2br }}</p>
            </div>

            {# Amenities #}
            <div class="room-detail-card">
                <h6 class="fw-700 mb-3"><i class="bi bi-stars me-2 text-primary"></i>Tiện ích & Chính sách</h6>
                {% set amenities = [
                    ['has_wifi',            'bi-wifi',      'WiFi'],
                    ['has_ac',              'bi-snow2',     'Điều hòa'],
                    ['has_parking',         'bi-car-front', 'Gửi xe'],
                    ['has_kitchen',         'bi-cup-hot',   'Bếp nấu'],
                    ['has_washing_machine', 'bi-recycle',   'Máy giặt'],
                    ['has_fridge',          'bi-box',       'Tủ lạnh'],
                    ['has_private_bath',    'bi-droplet',   'WC riêng'],
                    ['allow_pet',           'bi-heart',     'Nuôi thú cưng'],
                    ['allow_cooking',       'bi-fire',      'Nấu ăn']
                ] %}
                <div class="amenity-grid">
                    {% for item in amenities %}
                        <div class="amenity-item {{ room[item[0]] ? 'yes' : 'no' }}">
                            <i class="bi {{ item[1] }} amenity-icon"></i>
                            <span>{{ item[2] }}</span>
                            <i class="bi bi-{{ room[item[0]] ? 'check-circle-fill' : 'x-circle' }} ms-auto"></i>
                        </div>
                    {% endfor %}
                </div>
            </div>

            {# Fees #}
            <div class="room-detail-card">
                <h6 class="fw-700 mb-3"><i class="bi bi-receipt me-2 text-primary"></i>Chi phí hàng tháng</h6>
                <table class="table table-sm table-borderless">
                    <tbody>
                        <tr>
                            <td class="text-muted">Tiền phòng</td>
                            <td class="fw-700 text-primary">{{ room.price|money }}/tháng</td>
                        </tr>
                        {% if room.electric_price > 0 %}
                            <tr>
                                <td class="text-muted"><i class="bi bi-lightning me-1"></i>Điện</td>
                                <td>{{ room.electric_price|money }}/kWh</td>
                            </tr>
                        {% endif %}
                        {% if room.water_price > 0 %}
                            <tr>
                                <td class="text-muted"><i class="bi bi-droplet me-1"></i>Nước</td>
                                <td>{{ room.water_price|money }}/m³</td>
                            </tr>
                        {% endif %}
                        {% if room.internet_price > 0 %}
                            <tr>
                                <td class="text-muted"><i class="bi bi-wifi me-1"></i>Internet</td>
                                <td>{{ room.internet_price|money }}/tháng</td>
                            </tr>
                        {% endif %}
                        <tr class="table-light fw-600">
                            <td>Đặt cọc</td>
                            <td>{{ (room.price * room.deposit_months)|money }} ({{ room.deposit_months }} tháng)</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            {# Reviews #}
            <div class="room-detail-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-700 mb-0">
                        <i class="bi bi-star me-2 text-warning"></i>Đánh giá ({{ reviews|length }})
                    </h6>
                    {% if room.avg_rating > 0 %}
                        <div class="d-flex align-items-center gap-2">
                            <span class="fs-4 fw-800 text-warning">{{ room.avg_rating }}</span>
                            <div>
                                {{ stars(room.avg_rating) }}
                                <div class="small text-muted">{{ room.review_count }} đánh giá</div>
                            </div>
                        </div>
                    {% endif %}
                </div>

                {% if auth %}
                    <div class="bg-light rounded-3 p-3 mb-3">
                        <h6 class="fw-700 mb-3 small">Viết đánh giá</h6>
                        <form action="{{ route('/reviews') }}" method="POST">
                            <input type="hidden" name="room_id" value="{{ room.id }}">
                            <div class="mb-2">
                                <div class="star-rating-input">
                                    {% for i in range(5,1,-1) %}
                                        <input type="radio" name="rating" id="star{{ i }}" value="{{ i }}">
                                        <label for="star{{ i }}">
                                            <i class="bi bi-star-fill"></i>
                                        </label>
                                    {% endfor %}
                                </div>
                            </div>
                            <textarea name="comment" class="form-control form-control-sm mb-2"
                                rows="2" placeholder="Nhận xét của bạn..."></textarea>
                            <button type="submit" class="btn btn-primary btn-sm">Gửi đánh giá</button>
                        </form>
                    </div>
                {% endif %}

                {% if reviews is empty %}
                    <p class="text-muted small text-center py-3">Chưa có đánh giá nào.</p>
                {% else %}
                    {% for rv in reviews %}
                        <div class="review-card">
                            <div class="d-flex gap-3">
                                <div class="user-avatar-sm flex-shrink-0">
                                    {{ rv.user_name|slice(0,1)|upper }}
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <div class="fw-600 small">{{ rv.user_name }}</div>
                                            {{ stars(rv.rating) }}
                                        </div>
                                        <div class="small text-muted">
                                            {{ rv.created_at|date('d/m/Y') }}
                                        </div>
                                    </div>
                                    {% if rv.comment %}
                                        <p class="mb-0 mt-1 small">{{ rv.comment }}</p>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>

            {# Related #}
            {% if related is not empty %}
                <div>
                    <h6 class="fw-700 mb-3">
                        <i class="bi bi-grid me-2 text-primary"></i>Phòng tương tự
                    </h6>
                    <div class="row g-3">
                        {% for relRoom in related %}
                            <div class="col-sm-6">
                                {% include 'components/_room_card.twig' with { room: relRoom } %}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>

        {# ── RIGHT ── #}
        <div class="col-lg-4">

            <div class="detail-price-box mb-3">
                <div class="detail-price-big">{{ room.price|money }}</div>
                <div class="opacity-75 small">/ tháng</div>
                <div class="mt-2 d-flex align-items-center gap-2">
                    {% if room.is_available %}
                        <span class="badge bg-success">
                            <i class="bi bi-check-circle me-1"></i>Còn trống
                        </span>
                    {% else %}
                        <span class="badge bg-secondary">Đã cho thuê</span>
                    {% endif %}
                    {% if room.available_from %}
                        <span class="small opacity-75">Từ {{ room.available_from|date('d/m/Y') }}</span>
                    {% endif %}
                </div>
            </div>

            <div class="contact-card mb-3">
                <h6 class="fw-700 mb-3">
                    <i class="bi bi-person-circle me-2"></i>Liên hệ chủ trọ
                </h6>
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="user-avatar-sm" style="width:48px;height:48px;font-size:20px;">
                        {{ (room.contact_name ?? room.landlord_name ?? 'C')|slice(0,1)|upper }}
                    </div>
                    <div>
                        <div class="fw-700 text-white">
                            {{ room.contact_name ?? room.landlord_name }}
                        </div>
                        <div class="text-white-50 small">Chủ phòng trọ</div>
                    </div>
                </div>

                <a href="tel:{{ room.contact_phone }}" class="btn btn-primary w-100 fw-600 mb-3">
                    <i class="bi bi-telephone-fill me-2"></i>{{ room.contact_phone }}
                </a>

                <hr style="border-color:rgba(255,255,255,.2)">
                <p class="text-white-50 small mb-3">Hoặc gửi tin nhắn:</p>

                <form action="{{ route('/contact') }}" method="POST">
                    <input type="hidden" name="room_id" value="{{ room.id }}">
                    <div class="mb-2">
                        <input type="text" name="sender_name" class="form-control form-control-sm"
                            placeholder="Họ và tên *" required value="{{ auth.name ?? '' }}">
                    </div>
                    <div class="mb-2">
                        <input type="tel" name="sender_phone" class="form-control form-control-sm"
                            placeholder="Số điện thoại">
                    </div>
                    <div class="mb-2">
                        <input type="email" name="sender_email" class="form-control form-control-sm"
                            placeholder="Email" value="{{ auth.email ?? '' }}">
                    </div>
                    <div class="mb-2">
                        <textarea name="message" class="form-control form-control-sm" rows="3" required
                            >Xin chào, tôi quan tâm đến phòng "{{ room.title|truncate(40) }}". Vui lòng liên hệ!</textarea>
                    </div>
                    <button type="submit" class="btn btn-light w-100 fw-700" style="color:var(--secondary)">
                        <i class="bi bi-send me-2"></i>Gửi liên hệ
                    </button>
                </form>
            </div>

            <div class="room-detail-card">
                <div class="d-flex gap-2">
                    <button onclick="navigator.share
                        ? navigator.share({title:'{{ room.title|e('js') }}',url:location.href})
                        : (navigator.clipboard.writeText(location.href), showToast('Đã copy link!','success'))"
                        class="btn btn-outline-secondary btn-sm flex-fill">
                        <i class="bi bi-share me-1"></i>Chia sẻ
                    </button>
                    <button onclick="window.print()"
                        class="btn btn-outline-secondary btn-sm flex-fill">
                        <i class="bi bi-printer me-1"></i>In
                    </button>
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
{% if images is not empty %}
var rgSrcs = [{% for img in images %}"{{ (upload_url ~ img.image_path)|e('js') }}"{{ not loop.last ? ',' : '' }}{% endfor %}];
var rgIdx  = 0;

function rgGoTo(idx) {
    if (idx < 0) idx = rgSrcs.length - 1;
    if (idx >= rgSrcs.length) idx = 0;
    rgIdx = idx;
    var img = document.getElementById('rgMainImg');
    img.classList.add('rg-fade');
    setTimeout(function() { img.src = rgSrcs[idx]; img.classList.remove('rg-fade'); }, 200);
    document.getElementById('rgCounter').textContent = (idx + 1) + ' / ' + rgSrcs.length;
    document.querySelectorAll('.rg-thumb').forEach(function(t, i) {
        t.classList.toggle('active', i === idx);
    });
    var thumbs = document.querySelectorAll('.rg-thumb');
    if (thumbs[idx]) thumbs[idx].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
}

function rgNav(dir) { rgGoTo(rgIdx + dir); }

function rgExpand(idx) {
    document.getElementById('rgLbImg').src = rgSrcs[idx];
    document.getElementById('rgLbCaption').textContent = (idx + 1) + ' / ' + rgSrcs.length;
    document.getElementById('rgLightbox').classList.add('open');
    document.body.style.overflow = 'hidden';
}

function rgCloseLb() {
    document.getElementById('rgLightbox').classList.remove('open');
    document.body.style.overflow = '';
}

function rgLbNav(dir) {
    var newIdx = rgIdx + dir;
    if (newIdx < 0) newIdx = rgSrcs.length - 1;
    if (newIdx >= rgSrcs.length) newIdx = 0;
    rgGoTo(newIdx);
    document.getElementById('rgLbImg').src = rgSrcs[newIdx];
    document.getElementById('rgLbCaption').textContent = (newIdx + 1) + ' / ' + rgSrcs.length;
}

document.addEventListener('keydown', function(e) {
    var lb = document.getElementById('rgLightbox');
    if (lb && lb.classList.contains('open')) {
        if (e.key === 'ArrowRight') rgLbNav(1);
        else if (e.key === 'ArrowLeft') rgLbNav(-1);
        else if (e.key === 'Escape') rgCloseLb();
    } else {
        if (e.key === 'ArrowRight') rgNav(1);
        else if (e.key === 'ArrowLeft') rgNav(-1);
    }
});
{% endif %}
</script>
{% endblock %}