{% extends 'layouts/base.twig' %}
{% block title %}Xác nhận đăng tin{% endblock %}

{% block content %}
<div class="container py-4">
    <div class="mb-3">
        <a href="{{ route('/posts/create') }}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
    </div>

    <h4 class="fw-bold mb-3">Xác nhận đăng tin cho BĐS</h4>

    <div class="card mb-4">
        <div class="card-body">
            <h5>{{ property.name }}</h5>
            <p class="text-muted mb-1">{{ property.address }}</p>
            <p class="mb-1">Loại: {{ property.type|replace({'_':' '})|title }}</p>
            <p>{{ property.description }}</p>
            <p class="small text-muted">Đăng bởi: bạn (user)</p>
        </div>
    </div>

    {% if existing %}
        <div class="alert alert-warning">BĐS này đã có bài đăng đang hoạt động (ID: {{ existing.id }}). Bạn vẫn có thể tạo bài đăng mới, nhưng có thể trùng nội dung.</div>
    {% endif %}

    <div class="d-flex gap-2 mb-4">
        <a href="{{ route('/blocks/' ~ property.id ~ '/edit') }}" class="btn btn-outline-primary">Chỉnh sửa BĐS</a>
        <form action="{{ route('/posts/create') }}" method="POST" class="d-inline-block">
            <input type="hidden" name="_csrf" value="{{ csrf }}">
            <input type="hidden" name="property_id" value="{{ property.id }}">
            <div class="mb-3">
                <label class="form-label">Tiêu đề bài đăng (tùy chọn)</label>
                <input type="text" name="title" class="form-control" placeholder="Để trống nếu lấy tự động" value="{{ property.name ? 'Cho thuê ' ~ property.name : '' }}">
            </div>
            <div class="mb-3">
                <label class="form-label">Mô tả bài đăng (tùy chọn)</label>
                <textarea name="description" class="form-control" rows="4">{{ property.description }}</textarea>
            </div>
            <button type="submit" class="btn btn-success">Xác nhận đăng tin</button>
        </form>
    </div>
</div>
{% endblock %}
