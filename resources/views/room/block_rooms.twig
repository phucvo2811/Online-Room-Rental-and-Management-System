{% extends 'layouts/base.twig' %}
{% block title %}Quản lý phòng - {{ block.name }}{% endblock %}

{% block content %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h4 class="fw-800 mb-1"><i class="bi bi-door-open me-2"></i>{{ block.name }}</h4>
            <p class="text-muted mb-0">{{ block.address }} · {{ block.room_count }} phòng</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            {% if block.type in ['boarding_house', 'dormitory', 'homestay'] %}
            <a href="{{ route('/blocks/' ~ block.id ~ '/rooms/create') }}" class="btn btn-primary btn-sm">Thêm phòng</a>
            {% endif %}
        </div>
    </div>

    {% if block.type in ['boarding_house', 'dormitory', 'homestay'] %}
    <div class="card mb-3">
        <div class="card-body">
            <form action="{{ route('/blocks/' ~ block.id ~ '/rooms/bulk-create') }}" method="POST" class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">Tiền tố</label>
                    <input type="text" class="form-control" name="prefix" value="Phòng " required>
                </div>
                <div class="col-md-1">
                    <label class="form-label">Từ</label>
                    <input type="number" class="form-control" name="start" value="1" min="1">
                </div>
                <div class="col-md-1">
                    <label class="form-label">Đến</label>
                    <input type="number" class="form-control" name="end" value="5" min="1">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Loại phòng</label>
                    <select class="form-select" name="room_type_id">
                        <option value="">-- Chọn --</option>
                        {% for type in types %}
                            <option value="{{ type.id }}">{{ type.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Giá (VNĐ)</label>
                    <input type="number" class="form-control" name="price" placeholder="3.500.000">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Diện tích (m²)</label>
                    <input type="number" class="form-control" name="area" placeholder="25">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-success w-100">Tạo nhanh</button>
                </div>
            </form>
        </div>
    </div>
    {% else %}
    <div class="alert alert-info mb-3">
        <i class="bi bi-info-circle me-2"></i>
        <strong>Căn hộ Mini / Nhà nguyên căn</strong> là bất động sản đơn lẻ, không cần thêm phòng riêng lẻ.
    </div>
    {% endif %}

    {% if rooms is empty %}
        <div class="empty-state">
            <div class="icon"><i class="bi bi-door-open"></i></div>
            <h5>Chưa có phòng nào</h5>
            <p>Hãy thêm phòng hoặc dùng tính năng tạo nhanh để tạo 10-20 phòng chỉ trong vài giây.</p>
        </div>
    {% else %}
        <div class="block-room-actions d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
            <div><strong id="selectedRoomCount">0</strong> / {{ rooms|length }} phòng được chọn</div>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="resetSelectedRooms()">Bỏ chọn</button>
                <button type="button" class="btn btn-outline-primary btn-sm" onclick="selectAllRooms()">Chọn tất cả</button>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3">
            {% for r in rooms %}
                {% set statusClass = r.occupancy_status == 'available' ? 'success' : (r.occupancy_status == 'rented' ? 'danger' : 'warning') %}
                <div class="col">
                    <div class="room-card card h-100 position-relative" data-room-id="{{ r.id }}" onclick="toggleRoomCardSelection(this)">
                        <input type="checkbox" class="room-select-input d-none" name="selected_rooms[]" value="{{ r.id }}">
                        <div class="room-type-badge">{{ r.occupancy_status == 'available' ? 'Còn trống' : (r.occupancy_status == 'rented' ? 'Đã thuê' : 'Đang sửa') }}</div>
                        <div class="card-body p-3">
                            <h6 class="room-title mb-1">{{ r.name }}</h6>
                            <p class="room-address mb-1 small">{{ r.room_type_name|default('Chưa chọn') }}</p>
                            <div class="room-meta mb-1">
                                <span class="badge bg-{{ statusClass }} text-white">{{ r.price|money }}/tháng</span>
                                <span class="text-muted ms-auto">{{ r.area }} m²</span>
                            </div>
                            <div class="mt-auto d-flex flex-column gap-1">
                                {# Occupancy toggle #}
                                <form action="{{ route('/blocks/' ~ block.id ~ '/rooms/' ~ r.id ~ '/occupancy') }}" method="POST"
                                      onclick="event.stopPropagation();" onsubmit="event.stopPropagation();">
                                    {% if r.occupancy_status == 'available' %}
                                        <input type="hidden" name="occupancy_status" value="rented">
                                        <button type="submit" class="btn btn-sm btn-warning w-100">
                                            <i class="bi bi-person-check me-1"></i>Đánh dấu đã thuê
                                        </button>
                                    {% elseif r.occupancy_status == 'rented' %}
                                        <input type="hidden" name="occupancy_status" value="available">
                                        <button type="submit" class="btn btn-sm btn-success w-100">
                                            <i class="bi bi-door-open me-1"></i>Mở lại (còn trống)
                                        </button>
                                    {% else %}
                                        <input type="hidden" name="occupancy_status" value="available">
                                        <button type="submit" class="btn btn-sm btn-outline-success w-100">
                                            <i class="bi bi-tools me-1"></i>Xong sửa chữa
                                        </button>
                                    {% endif %}
                                </form>
                                <div class="d-flex gap-1">
                                    <a href="{{ route('/rooms/' ~ r.id ~ '/edit') }}"
                                       class="btn btn-sm btn-outline-secondary flex-grow-1"
                                       onclick="event.stopPropagation();">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form action="{{ route('/rooms/' ~ r.id ~ '/delete') }}" method="POST"
                                          onsubmit="event.stopPropagation(); return confirm('Xóa phòng này?');"
                                          class="flex-grow-1">
                                        <button class="btn btn-sm btn-outline-danger w-100"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
