<!DOCTYPE html>
<html lang="vi" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ page_title ?? 'Trang chủ' }}{% endblock %} — {{ app_name }}</title>
    <meta name="description" content="{% block meta_desc %}Tìm phòng trọ, căn hộ mini uy tín tại Cần Thơ{% endblock %}">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <link href="{{ asset('css/app.css') }}" rel="stylesheet">
    {% block head %}{% endblock %}
</head>
<body>

{# ── NAVBAR ── #}
<nav class="navbar navbar-expand-lg sticky-top navbar-custom" id="mainNavbar">
    <div class="container">

        <a class="navbar-brand d-flex align-items-center gap-2" href="{{ route('/') }}">
            <div class="brand-icon"><i class="bi bi-house-heart-fill"></i></div>
            <div>
                <span class="brand-name">PhòngTrọ</span>
                <span class="brand-city">Cần Thơ</span>
            </div>
        </a>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMain">

            <form class="nav-search mx-auto d-none d-lg-flex" action="{{ route('/rooms') }}" method="GET">
                <div class="nav-search-inner">
                    <i class="bi bi-search"></i>
                    <input type="text" name="keyword" class="form-control border-0 shadow-none"
                        placeholder="Tìm đường, khu vực..."
                        value="{{ app.get.keyword ?? '' }}">
                    <button type="submit" class="btn btn-primary btn-sm px-3">Tìm</button>
                </div>
            </form>

            <ul class="navbar-nav ms-auto align-items-center gap-1">

                <li class="nav-item">
                    <a class="nav-link" href="{{ route('/rooms') }}">
                        <i class="bi bi-grid me-1"></i>Xem phòng
                    </a>
                </li>

                {% if session.user_id %}

                    {# Bell #}
                    <li class="nav-item dropdown">
                        <a class="nav-link position-relative" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-bell fs-5"></i>
                            {% set unread = unread_notifs ?? 0 %}
                            {% if unread > 0 %}
                                <span class="notif-badge">{{ unread }}</span>
                            {% endif %}
                        </a>
                        <div class="dropdown-menu dropdown-menu-end notif-dropdown p-0 shadow-lg">
                            <div class="notif-header">
                                <span class="fw-600">Thông báo</span>
                            </div>
                            <div class="text-center py-3 text-muted small">
                                <a href="{{ route('/dashboard') }}">Xem tất cả thông báo</a>
                            </div>
                        </div>
                    </li>

                    {# User dropdown #}
                    <li class="nav-item dropdown">
                        <a class="nav-link d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
                            <div class="user-avatar-sm">
                                {% if session.user_avatar %}
                                    <img src="{{ upload_url ~ session.user_avatar }}" alt="">
                                {% else %}
                                    <span>{{ session.user_name|slice(0,1)|upper }}</span>
                                {% endif %}
                            </div>
                            <span class="d-none d-lg-inline fw-500">{{ session.user_name }}</span>
                            <i class="bi bi-chevron-down small"></i>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                            <li>
                                <div class="dropdown-header">
                                    <div class="fw-600">{{ session.user_name }}</div>
                                    <div class="small text-muted">
                                        {% if session.user_role == 'admin' %}Quản trị viên
                                        {% elseif session.user_role == 'landlord' %}Chủ trọ
                                        {% else %}Người thuê{% endif %}
                                    </div>
                                </div>
                            </li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <a class="dropdown-item" href="{{ route('/dashboard') }}">
                                    <i class="bi bi-speedometer2 me-2"></i>Dashboard
                                </a>
                            </li>
                            {% if session.user_role in ['landlord','admin'] %}
                                <li>
                                    <a class="dropdown-item" href="{{ route('/rooms/create') }}">
                                        <i class="bi bi-plus-circle me-2"></i>Đăng tin
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="{{ route('/my-rooms') }}">
                                        <i class="bi bi-house me-2"></i>Phòng của tôi
                                    </a>
                                </li>
                            {% endif %}
                            {% if session.user_role == 'admin' %}
                                <li>
                                    <a class="dropdown-item text-danger" href="{{ route('/admin') }}">
                                        <i class="bi bi-shield-check me-2"></i>Admin Panel
                                    </a>
                                </li>
                            {% endif %}
                            <li>
                                <a class="dropdown-item" href="{{ route('/favorites') }}">
                                    <i class="bi bi-heart me-2"></i>Yêu thích
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="{{ route('/profile') }}">
                                    <i class="bi bi-person me-2"></i>Hồ sơ
                                </a>
                            </li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="{{ route('/logout') }}">
                                    <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                </a>
                            </li>
                        </ul>
                    </li>

                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ route('/login') }}">Đăng nhập</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-primary btn-sm px-3 ms-1" href="{{ route('/register') }}">
                            <i class="bi bi-person-plus me-1"></i>Đăng ký
                        </a>
                    </li>
                {% endif %}

                {% if session.user_role in ['landlord','admin'] %}
                    <li class="nav-item ms-1">
                        <a class="btn btn-success btn-sm px-3" href="{{ route('/rooms/create') }}">
                            <i class="bi bi-plus-lg me-1"></i>Đăng tin
                        </a>
                    </li>
                {% endif %}

            </ul>
        </div>
    </div>
</nav>

{# ── FLASH MESSAGES ── #}
{% for type, message in flash %}
    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show mb-0 rounded-0 border-0" role="alert">
        <div class="container">
            <i class="bi bi-{{ type == 'success' ? 'check-circle' : (type == 'danger' ? 'exclamation-triangle' : 'info-circle') }} me-2"></i>
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
{% endfor %}

{# ── MAIN ── #}
<main>
    {% block content %}{% endblock %}
</main>

{# ── FOOTER ── #}
<footer class="footer-main mt-5">
    <div class="footer-top">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="brand-icon"><i class="bi bi-house-heart-fill"></i></div>
                        <div>
                            <span class="brand-name text-white">PhòngTrọ</span>
                            <span class="brand-city text-white opacity-75">Cần Thơ</span>
                        </div>
                    </div>
                    <p class="text-white-50 small">Nền tảng tìm phòng trọ uy tín số 1 tại Cần Thơ. Kết nối chủ trọ và người thuê nhanh chóng, minh bạch.</p>
                    <div class="d-flex gap-2 mt-3">
                        <a href="#" class="btn-social"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="btn-social"><i class="bi bi-tiktok"></i></a>
                        <a href="#" class="btn-social"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>
                <div class="col-6 col-lg-2">
                    <h6 class="text-white fw-600 mb-3">Khu vực</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a href="{{ route('/rooms') }}?district_id=1">Ninh Kiều</a></li>
                        <li><a href="{{ route('/rooms') }}?district_id=2">Bình Thủy</a></li>
                        <li><a href="{{ route('/rooms') }}?district_id=3">Cái Răng</a></li>
                        <li><a href="{{ route('/rooms') }}?district_id=4">Ô Môn</a></li>
                        <li><a href="{{ route('/rooms') }}?district_id=5">Thốt Nốt</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h6 class="text-white fw-600 mb-3">Loại phòng</h6>
                    <ul class="list-unstyled footer-links">
                        {% for key, label in room_types %}
                            <li><a href="{{ route('/rooms') }}?room_type={{ key }}">{{ label }}</a></li>
                        {% endfor %}
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h6 class="text-white fw-600 mb-3">Liên hệ & Hỗ trợ</h6>
                    <ul class="list-unstyled text-white-50 small">
                        <li class="mb-2"><i class="bi bi-geo-alt me-2 text-primary"></i>Số 1, Đại lộ Hòa Bình, Q.Ninh Kiều, Cần Thơ</li>
                        <li class="mb-2"><i class="bi bi-telephone me-2 text-primary"></i>0292 123 456</li>
                        <li class="mb-2"><i class="bi bi-envelope me-2 text-primary"></i>support@phongtro.com</li>
                        <li class="mb-2"><i class="bi bi-clock me-2 text-primary"></i>7:00 – 21:00, Thứ 2 – Chủ nhật</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <div class="footer-bottom">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
            <span class="text-white-50 small">© {{ current_year }} {{ app_name }}. Bảo lưu mọi quyền.</span>
            <div class="d-flex gap-3">
                <a href="#" class="text-white-50 small text-decoration-none">Điều khoản</a>
                <a href="#" class="text-white-50 small text-decoration-none">Bảo mật</a>
            </div>
        </div>
    </div>
</footer>

<button class="btn-back-top" id="btnBackTop"><i class="bi bi-arrow-up"></i></button>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ asset('js/app.js') }}"></script>
{% block scripts %}{% endblock %}
</body>
</html>